{
  "name": "@hospital-lms/notebook-worker",
  "version": "0.1.0",
  "private": true,
  "description": "NotebookLM (notebooklm-py) wrapper worker service. Spawns the Python CLI, manages per-org Playwright storage_state, uploads artifacts to S3.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "express": "^4.21.2",
    "pino": "^9.5.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
