{
  "name": "hospital-lms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/predev.js",
    "dev": "next dev --turbopack",
    "dev:webpack": "node scripts/predev.js && next dev --webpack",
    "dev:clean": "rm -rf .next .next.nosync '.next 2' '.next.nosync 2' && pnpm predev && next dev --turbopack",
    "build": "prisma generate && next build",
    "build:prod": "node scripts/validate-env.js && pnpm build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test",
    "test:e2e:prod": "playwright test --config=playwright.prod.config.ts",
    "setup": "node scripts/setup.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node scripts/seed-demo.js",
    "seed:smg": "tsx scripts/seed-smg-categories.ts",
    "prepare": "husky",
    "validate:env": "node scripts/validate-env.js",
    "predeploy": "node scripts/validate-env.js",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test:load": "k6 run scripts/load-test.js",
    "verify:backup": "node scripts/verify-backup.js",
    "remotion:studio": "remotion studio src/remotion/index.ts --port 3001",
    "brand:reveal": "remotion render src/remotion/index.ts KlinovaLogoReveal public/brand/klinova-reveal.mp4",
    "brand:splash": "remotion render src/remotion/index.ts KlinovaSplash public/brand/klinova-splash.mp4",
    "brand:intro": "remotion render src/remotion/index.ts KlinovaIntro public/brand/klinova-intro.mp4",
    "brand:splash-png": "remotion still src/remotion/index.ts KlinovaSplash public/brand/klinova-splash.png --frame=30"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "core-js",
      "msw",
      "sharp",
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ]
  },
  "lint-staged": {
    "*": [
      "node scripts/secret-scanner.js"
    ],
    "src/app/api/**/route.ts": [
      "node scripts/perf-check.js"
    ],
    "src/app/**/page.{ts,tsx}": [
      "node scripts/perf-check.js"
    ],
    "src/app/{staff,admin,super-admin,help}/**/*.{ts,tsx}": [
      "bash scripts/editorial-palette-guard.sh"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@aws-sdk/cloudfront-signer": "^3.1012.0",
    "@aws-sdk/s3-request-presigner": "^3.1016.0",
    "@base-ui/react": "^1.3.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@paper-design/shaders-react": "^0.0.76",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@remotion/cli": "^4.0.448",
    "@remotion/player": "^4.0.448",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@types/qrcode": "^1.5.6",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "html2canvas-pro": "^2.0.2",
    "jose": "^6.2.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.6.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.3",
    "openai": "^6.35.0",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-pdf": "^10.4.1",
    "recharts": "^3.8.0",
    "remotion": "^4.0.448",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "xml-crypto": "^6.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@types/xml-crypto": "^1.4.6",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.1",
    "wait-on": "^9.0.5"
  }
}
