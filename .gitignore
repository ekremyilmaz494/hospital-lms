# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next.nosync/
/.next-build-*/
/out/

# next-pwa / Serwist build artifacts (her build'de hash değişir)
# 2026-05-11: public/sw.js artık kill-switch SW olarak commit edildi — eski
# next-pwa cache'lerini temizler ve kendini unregister eder. PWA disabled
# olduğu için build bu dosyayı overwrite etmez. Diğer worker pattern'leri
# (workbox/swe-worker/worker-) gelecekte tekrar PWA açılırsa diye gitignored kalır.
/public/sw.js.map
/public/swe-worker-*.js
/public/swe-worker-*.js.map
/public/workbox-*.js
/public/workbox-*.js.map
/public/worker-*.js
/public/worker-*.js.map

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.reference

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Uploaded files (dev only)
/public/uploads/

# Screenshots (dev only)
/screenshots/

# Playwright
/take-screenshots.mjs
/playwright-report
/test-results
/.playwright

/packages/**/dist/

# Workspace artifacts
*.zip
"Klinova — Admin Paneli (Print).html"
/scripts/_login-shot 2.mjs

# Claude Code hook logs
.claude/command-log.txt
# Claude Code scheduler runtime lock (per-machine, must not sync)
.claude/scheduled_tasks.lock
tmp/
/tmp/
# Geçici smoke test fixture'ları (örn. scripts/smoke-*.mjs üretimleri)
/tmp-*
hospital-lms-next/

# Lock files — pnpm tek kaynak (CLAUDE.md). Vercel ve dev ortamının aynı lock'u kullanması için npm/yarn lock'ları commit edilmez.
package-lock.json
yarn.lock

# generated PDF outputs
/hospital-admin-rehberi.pdf

# Local secrets (CloudFront private key, env backups)
.secrets/

# Test seed scripti çıktıları (TC + parola içerir, asla commit etme)
tmp-test-users-credentials.txt
tmp-seed-log.txt
.env*.local

# Lokal admin yardımcı scriptleri (plaintext credential içerebilir, repoya gitmemeli)
scripts/create-super-admin.mjs
scripts/fix-super-admin-kvkk.mjs

# Yerel binary/rapor dosyaları (proje dizini geçici sahnesi olarak kullanılınca biriken artıklar)
*.dmg
tamamlama_raporu.pdf
