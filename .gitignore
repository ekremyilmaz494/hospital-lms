# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Uploaded files (dev only)
/public/uploads/

# Screenshots (dev only)
/screenshots/

# Playwright
/take-screenshots.mjs
/playwright-report
/test-results

# AI Content Service
ai-content-service/browser_profiles/
ai-content-service/auth_store/*.enc
ai-content-service/temp/
ai-content-service/.env
ai-content-service/_auth_b64.txt

# Claude Code hook logs
.claude/command-log.txt
