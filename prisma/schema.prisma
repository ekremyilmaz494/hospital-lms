generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── ABONELIK PLANLARI ──
model SubscriptionPlan {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(100)
  slug            String   @unique @db.VarChar(50)
  description     String?  @db.Text
  maxStaff        Int?     @map("max_staff")
  maxTrainings    Int?     @map("max_trainings")
  maxStorageGb    Int      @default(10) @map("max_storage_gb")
  priceMonthly    Decimal? @db.Decimal(10, 2) @map("price_monthly")
  priceAnnual     Decimal? @db.Decimal(10, 2) @map("price_annual")
  features        Json     @default("[]")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  subscriptions   OrganizationSubscription[]

  @@map("subscription_plans")
}

// ── HASTANELER ──
model Organization {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(255)
  code            String   @unique @db.VarChar(50)
  address         String?  @db.Text
  phone           String?  @db.VarChar(20)
  email           String?  @db.VarChar(255)
  logoUrl         String?  @db.Text @map("logo_url")
  isActive        Boolean  @default(true) @map("is_active")
  isSuspended     Boolean  @default(false) @map("is_suspended")
  suspendedReason String?  @db.Text @map("suspended_reason")
  suspendedAt     DateTime? @map("suspended_at") @db.Timestamptz
  sessionTimeout  Int      @default(30) @map("session_timeout")
  defaultPassingScore     Int @default(70) @map("default_passing_score")
  defaultMaxAttempts      Int @default(3) @map("default_max_attempts")
  defaultExamDuration     Int @default(30) @map("default_exam_duration")
  // SSO / SAML Configuration
  ssoEnabled         Boolean  @default(false) @map("sso_enabled")
  ssoProvider        String?  @db.VarChar(50) @map("sso_provider")
  ssoEmailDomain     String?  @db.VarChar(255) @map("sso_email_domain")
  samlEntryPoint     String?  @db.Text @map("saml_entry_point")
  samlIssuer         String?  @db.Text @map("saml_issuer")
  samlCert           String?  @db.Text @map("saml_cert")
  oidcDiscoveryUrl   String?  @db.Text @map("oidc_discovery_url")
  oidcClientId       String?  @db.VarChar(255) @map("oidc_client_id")
  oidcClientSecret   String?  @db.Text @map("oidc_client_secret")
  ssoAutoProvision   Boolean  @default(true) @map("sso_auto_provision")
  ssoDefaultRole     String   @default("staff") @db.VarChar(20) @map("sso_default_role")

  createdBy       String?  @db.Uuid @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  users           User[]
  departments     Department[]
  trainings       Training[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  dbBackups       DbBackup[]
  subscription    OrganizationSubscription?
  kvkkRequests    KvkkRequest[]
  smgActivities   SmgActivity[]
  smgPeriods      SmgPeriod[]
  contentLibraryInstalls OrganizationContentLibrary[]
  hisIntegrations HisIntegration[]
  competencyForms CompetencyForm[]
  syncLogs        SyncLog[]

  @@map("organizations")
}

// ── HASTANE ABONELİKLERİ ──
model OrganizationSubscription {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @unique @db.Uuid @map("organization_id")
  planId          String   @db.Uuid @map("plan_id")
  status          String   @default("trial") @db.VarChar(20)
  billingCycle    String?  @db.VarChar(10) @map("billing_cycle")
  trialEndsAt     DateTime? @map("trial_ends_at") @db.Timestamptz
  startedAt       DateTime @default(now()) @map("started_at") @db.Timestamptz
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz
  notes           String?  @db.Text
  createdBy       String?  @db.Uuid @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan            SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments        Payment[]
  invoices        Invoice[]

  @@map("organization_subscriptions")
}

// ── ÖDEMELER ──
model Payment {
  id                  String    @id @default(uuid()) @db.Uuid
  subscriptionId      String    @db.Uuid @map("subscription_id")
  organizationId      String    @db.Uuid @map("organization_id")
  amount              Decimal   @db.Decimal(10, 2)
  currency            String    @default("TRY") @db.VarChar(3)
  status              String    @default("pending") @db.VarChar(20)
  paymentMethod       String?   @db.VarChar(30) @map("payment_method")
  iyzicoPaymentId     String?   @db.VarChar(100) @map("iyzico_payment_id")
  iyzicoConversationId String?  @db.VarChar(100) @map("iyzico_conversation_id")
  cardLastFour        String?   @db.VarChar(4) @map("card_last_four")
  cardBrand           String?   @db.VarChar(20) @map("card_brand")
  errorMessage        String?   @db.Text @map("error_message")
  paidAt              DateTime? @map("paid_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  subscription        OrganizationSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoice             Invoice?

  @@index([organizationId], map: "idx_payments_org")
  @@index([organizationId, status], map: "idx_payments_org_status")
  @@index([iyzicoPaymentId], map: "idx_payments_iyzico")
  @@map("payments")
}

// ── FATURALAR ──
model Invoice {
  id                String    @id @default(uuid()) @db.Uuid
  paymentId         String    @unique @db.Uuid @map("payment_id")
  subscriptionId    String    @db.Uuid @map("subscription_id")
  organizationId    String    @db.Uuid @map("organization_id")
  invoiceNumber     String    @unique @db.VarChar(30) @map("invoice_number")
  amount            Decimal   @db.Decimal(10, 2)
  taxAmount         Decimal   @default(0) @db.Decimal(10, 2) @map("tax_amount")
  totalAmount       Decimal   @db.Decimal(10, 2) @map("total_amount")
  currency          String    @default("TRY") @db.VarChar(3)
  billingName       String    @db.VarChar(255) @map("billing_name")
  billingAddress    String?   @db.Text @map("billing_address")
  taxNumber         String?   @db.VarChar(20) @map("tax_number")
  taxOffice         String?   @db.VarChar(100) @map("tax_office")
  periodStart       DateTime  @map("period_start") @db.Timestamptz
  periodEnd         DateTime  @map("period_end") @db.Timestamptz
  issuedAt          DateTime  @default(now()) @map("issued_at") @db.Timestamptz

  payment           Payment  @relation(fields: [paymentId], references: [id])
  subscription      OrganizationSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([organizationId], map: "idx_invoices_org")
  @@index([invoiceNumber], map: "idx_invoices_number")
  @@map("invoices")
}

// ── DEPARTMANLAR ──
model Department {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid @map("organization_id")
  name            String   @db.VarChar(100)
  description     String?  @db.Text
  color           String   @default("#0d9668") @db.VarChar(7)
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users           User[]
  trainingRules   DepartmentTrainingRule[]

  @@unique([organizationId, name])
  @@index([organizationId], map: "idx_departments_org")
  @@map("departments")
}

// ── KULLANICILAR ──
model User {
  id              String   @id @db.Uuid
  organizationId  String?  @db.Uuid @map("organization_id")
  email           String   @unique @db.VarChar(255)
  firstName       String   @db.VarChar(100) @map("first_name")
  lastName        String   @db.VarChar(100) @map("last_name")
  tcNo            String?  @db.VarChar(11) @map("tc_no")
  phone           String?  @db.VarChar(20)
  departmentId    String?  @db.Uuid @map("department_id")
  title           String?  @db.VarChar(100)
  role            String   @db.VarChar(20)
  avatarUrl       String?  @db.Text @map("avatar_url")
  isActive        Boolean  @default(true) @map("is_active")
  kvkkConsent     Boolean  @default(false) @map("kvkk_consent")
  kvkkConsentDate DateTime? @map("kvkk_consent_date") @db.Timestamptz
  hisExternalId   String?  @db.VarChar(100) @map("his_external_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization? @relation(fields: [organizationId], references: [id])
  departmentRel   Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdTrainings Training[]   @relation("TrainingCreator")
  assignments     TrainingAssignment[] @relation("AssignedUser")
  assignedBy      TrainingAssignment[] @relation("AssignedByUser")
  examAttempts    ExamAttempt[]
  videoProgress   VideoProgress[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  certificates    Certificate[]
  kvkkRequests    KvkkRequest[] @relation("KvkkRequester")
  kvkkResponses   KvkkRequest[] @relation("KvkkResponder")
  scormAttempts   ScormAttempt[]
  smgActivities   SmgActivity[] @relation("UserSmgActivities")
  smgApprovals    SmgActivity[] @relation("SmgApprovals")
  createdContentLibraries  ContentLibrary[]             @relation("ContentLibraryCreator")
  contentLibraryInstalls   OrganizationContentLibrary[] @relation("ContentLibraryInstaller")
  subjectEvaluations   CompetencyEvaluation[] @relation("EvaluationSubject")
  evaluatorEvaluations CompetencyEvaluation[] @relation("EvaluationEvaluator")
  pushSubscriptions    PushSubscription[]

  @@unique([organizationId, tcNo])
  @@index([organizationId], map: "idx_users_org")
  @@index([role], map: "idx_users_role")
  @@index([departmentId], map: "idx_users_department")
  @@index([hisExternalId], map: "idx_users_his_external_id")
  @@map("users")
}

// ── EĞİTİMLER ──
model Training {
  id                   String    @id @default(uuid()) @db.Uuid
  organizationId       String    @db.Uuid @map("organization_id")
  title                String    @db.VarChar(500)
  description          String?   @db.Text
  category             String?   @db.VarChar(100)
  thumbnailUrl         String?   @db.Text @map("thumbnail_url")
  passingScore         Int       @default(70) @map("passing_score")
  maxAttempts          Int       @default(3) @map("max_attempts")
  examDurationMinutes  Int       @default(30) @map("exam_duration_minutes")
  startDate            DateTime  @map("start_date") @db.Timestamptz
  endDate              DateTime  @map("end_date") @db.Timestamptz
  isActive             Boolean   @default(true) @map("is_active")
  // G5.4 — Yayın durumu: draft | published | archived
  publishStatus        String    @default("published") @db.VarChar(20) @map("publish_status")
  // Compliance / Uyum Alanları
  isCompulsory         Boolean   @default(false) @map("is_compulsory")
  complianceDeadline   DateTime? @map("compliance_deadline") @db.Timestamptz
  regulatoryBody       String?   @db.VarChar(200) @map("regulatory_body")
  renewalPeriodMonths  Int?      @map("renewal_period_months")
  createdById          String?   @db.Uuid @map("created_by")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // SCORM alanları
  scormManifestPath   String?   @db.Text @map("scorm_manifest_path")
  scormEntryPoint     String?   @db.Text @map("scorm_entry_point")
  scormVersion        String?   @db.VarChar(10) @map("scorm_version")

  // İçerik Kütüphanesi
  isFromLibrary       Boolean   @default(false) @map("is_from_library")
  sourceLibraryId     String?   @db.Uuid @map("source_library_id")

  organization        Organization    @relation(fields: [organizationId], references: [id])
  sourceLibrary       ContentLibrary? @relation("TrainingFromLibrary", fields: [sourceLibraryId], references: [id], onDelete: SetNull)
  createdBy           User?        @relation("TrainingCreator", fields: [createdById], references: [id])
  videos              TrainingVideo[]
  questions           Question[]
  assignments         TrainingAssignment[]
  examAttempts        ExamAttempt[]
  notifications       Notification[]
  certificates        Certificate[]
  scormAttempts       ScormAttempt[]
  departmentRules     DepartmentTrainingRule[]

  @@index([organizationId], map: "idx_trainings_org")
  @@index([startDate, endDate], map: "idx_trainings_dates")
  @@map("trainings")
}

// ── EĞİTİM VİDEOLARI ──
model TrainingVideo {
  id              String   @id @default(uuid()) @db.Uuid
  trainingId      String   @db.Uuid @map("training_id")
  title           String   @db.VarChar(500)
  description     String?  @db.Text
  videoUrl        String   @db.Text @map("video_url")
  videoKey        String   @db.Text @map("video_key")
  durationSeconds Int      @map("duration_seconds")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  training        Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  videoProgress   VideoProgress[]

  @@index([trainingId], map: "idx_training_videos_training")
  @@map("training_videos")
}

// ── SORULAR ──
model Question {
  id              String   @id @default(uuid()) @db.Uuid
  trainingId      String   @db.Uuid @map("training_id")
  questionText    String   @db.Text @map("question_text")
  questionType    String   @default("multiple_choice") @db.VarChar(20) @map("question_type")
  points          Int      @default(10)
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  training        Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  options         QuestionOption[]
  examAnswers     ExamAnswer[]

  @@index([trainingId], map: "idx_questions_training")
  @@map("questions")
}

// ── ŞIKLAR ──
model QuestionOption {
  id              String   @id @default(uuid()) @db.Uuid
  questionId      String   @db.Uuid @map("question_id")
  optionText      String   @db.Text @map("option_text")
  isCorrect       Boolean  @default(false) @map("is_correct")
  sortOrder       Int      @default(0) @map("sort_order")

  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  examAnswers     ExamAnswer[]

  @@index([questionId], map: "idx_question_options_question")
  @@map("question_options")
}

// ── EĞİTİM ATAMALARI ──
model TrainingAssignment {
  id              String    @id @default(uuid()) @db.Uuid
  trainingId      String    @db.Uuid @map("training_id")
  userId          String    @db.Uuid @map("user_id")
  status          String    @default("assigned") @db.VarChar(30)
  currentAttempt  Int       @default(0) @map("current_attempt")
  maxAttempts     Int       @default(3) @map("max_attempts")
  assignedById    String?   @db.Uuid @map("assigned_by")
  assignedAt      DateTime  @default(now()) @map("assigned_at") @db.Timestamptz
  completedAt     DateTime? @map("completed_at") @db.Timestamptz

  training        Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  user            User     @relation("AssignedUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy      User?    @relation("AssignedByUser", fields: [assignedById], references: [id])
  examAttempts    ExamAttempt[]

  @@unique([trainingId, userId])
  @@index([userId], map: "idx_assignments_user")
  @@index([trainingId], map: "idx_assignments_training")
  @@index([status], map: "idx_assignments_status")
  @@map("training_assignments")
}

// ── SINAV DENEMELERİ ──
model ExamAttempt {
  id                    String    @id @default(uuid()) @db.Uuid
  assignmentId          String    @db.Uuid @map("assignment_id")
  userId                String    @db.Uuid @map("user_id")
  trainingId            String    @db.Uuid @map("training_id")
  attemptNumber         Int       @map("attempt_number")
  preExamScore          Decimal?  @db.Decimal(5, 2) @map("pre_exam_score")
  postExamScore         Decimal?  @db.Decimal(5, 2) @map("post_exam_score")
  preExamStartedAt      DateTime? @map("pre_exam_started_at") @db.Timestamptz
  preExamCompletedAt    DateTime? @map("pre_exam_completed_at") @db.Timestamptz
  postExamStartedAt     DateTime? @map("post_exam_started_at") @db.Timestamptz
  postExamCompletedAt   DateTime? @map("post_exam_completed_at") @db.Timestamptz
  videosCompletedAt     DateTime? @map("videos_completed_at") @db.Timestamptz
  isPassed              Boolean   @default(false) @map("is_passed")
  status                String    @default("pre_exam") @db.VarChar(30)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz

  assignment            TrainingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user                  User               @relation(fields: [userId], references: [id])
  training              Training           @relation(fields: [trainingId], references: [id])
  examAnswers           ExamAnswer[]
  videoProgress         VideoProgress[]
  certificates          Certificate[]

  @@unique([assignmentId, attemptNumber])
  @@index([assignmentId], map: "idx_attempts_assignment")
  @@index([userId], map: "idx_attempts_user")
  @@index([trainingId], map: "idx_attempts_training")
  @@map("exam_attempts")
}

// ── SINAV CEVAPLARI ──
model ExamAnswer {
  id               String   @id @default(uuid()) @db.Uuid
  attemptId        String   @db.Uuid @map("attempt_id")
  questionId       String   @db.Uuid @map("question_id")
  selectedOptionId String?  @db.Uuid @map("selected_option_id")
  isCorrect        Boolean? @map("is_correct")
  examPhase        String   @db.VarChar(10) @map("exam_phase")
  answeredAt       DateTime @default(now()) @map("answered_at") @db.Timestamptz

  attempt          ExamAttempt    @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         Question       @relation(fields: [questionId], references: [id])
  selectedOption   QuestionOption? @relation(fields: [selectedOptionId], references: [id])

  @@unique([attemptId, questionId, examPhase])
  @@index([attemptId], map: "idx_exam_answers_attempt")
  @@map("exam_answers")
}

// ── VİDEO İZLEME TAKİBİ ──
model VideoProgress {
  id                  String    @id @default(uuid()) @db.Uuid
  attemptId           String    @db.Uuid @map("attempt_id")
  videoId             String    @db.Uuid @map("video_id")
  userId              String    @db.Uuid @map("user_id")
  watchedSeconds      Int       @default(0) @map("watched_seconds")
  totalSeconds        Int       @map("total_seconds")
  isCompleted         Boolean   @default(false) @map("is_completed")
  lastPositionSeconds Int       @default(0) @map("last_position_seconds")
  completedAt         DateTime? @map("completed_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  attempt             ExamAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  video               TrainingVideo @relation(fields: [videoId], references: [id])
  user                User          @relation(fields: [userId], references: [id])

  @@unique([attemptId, videoId])
  @@map("video_progress")
}

// ── BİLDİRİMLER ──
model Notification {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid @map("user_id")
  organizationId    String?  @db.Uuid @map("organization_id")
  title             String   @db.VarChar(500)
  message           String   @db.Text
  type              String   @db.VarChar(50)
  relatedTrainingId String?  @db.Uuid @map("related_training_id")
  isRead            Boolean  @default(false) @map("is_read")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization? @relation(fields: [organizationId], references: [id])
  relatedTraining   Training?     @relation(fields: [relatedTrainingId], references: [id])

  @@index([userId, isRead], map: "idx_notifications_user")
  @@index([userId, createdAt], map: "idx_notifications_user_date")
  @@map("notifications")
}

// ── DENETİM KAYITLARI ──
model AuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String?  @db.Uuid @map("user_id")
  organizationId  String?  @db.Uuid @map("organization_id")
  action          String   @db.VarChar(100)
  entityType      String   @db.VarChar(50) @map("entity_type")
  entityId        String?  @db.Uuid @map("entity_id")
  oldData         Json?    @map("old_data")
  newData         Json?    @map("new_data")
  ipAddress       String?  @db.VarChar(45) @map("ip_address")
  userAgent       String?  @db.Text @map("user_agent")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user            User?         @relation(fields: [userId], references: [id])
  organization    Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId], map: "idx_audit_logs_user")
  @@index([entityType, entityId], map: "idx_audit_logs_entity")
  @@index([createdAt], map: "idx_audit_logs_date")
  @@map("audit_logs")
}

// ── VERİTABANI YEDEKLERİ ──
model DbBackup {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String?  @db.Uuid @map("organization_id")
  backupType      String   @db.VarChar(20) @map("backup_type")
  fileUrl         String   @db.Text @map("file_url")
  fileSizeMb      Decimal? @db.Decimal(10, 2) @map("file_size_mb")
  status          String   @default("completed") @db.VarChar(20)
  createdById     String?  @db.Uuid @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization    Organization? @relation(fields: [organizationId], references: [id])

  @@map("db_backups")
}

// ── SERTİFİKALAR ──
model Certificate {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid @map("user_id")
  trainingId      String    @db.Uuid @map("training_id")
  attemptId       String    @unique @db.Uuid @map("attempt_id")
  certificateCode String    @unique @db.VarChar(50) @map("certificate_code")
  issuedAt        DateTime  @default(now()) @map("issued_at") @db.Timestamptz
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz

  user            User         @relation(fields: [userId], references: [id])
  training        Training     @relation(fields: [trainingId], references: [id])
  attempt         ExamAttempt  @relation(fields: [attemptId], references: [id])

  @@index([userId], map: "idx_certificates_user")
  @@index([trainingId], map: "idx_certificates_training")
  @@map("certificates")
}

// ── KVKK BAŞVURULARI ──
model KvkkRequest {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @db.Uuid @map("organization_id")
  userId          String    @db.Uuid @map("user_id")
  requestType     String    @db.VarChar(30) @map("request_type")
  status          String    @default("pending") @db.VarChar(20)
  description     String    @db.Text
  responseNote    String?   @db.Text @map("response_note")
  respondedById   String?   @db.Uuid @map("responded_by")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  completedAt     DateTime? @map("completed_at") @db.Timestamptz

  organization    Organization @relation(fields: [organizationId], references: [id])
  user            User      @relation("KvkkRequester", fields: [userId], references: [id])
  respondedBy     User?     @relation("KvkkResponder", fields: [respondedById], references: [id])

  @@index([organizationId, status], map: "idx_kvkk_requests_org_status")
  @@index([userId], map: "idx_kvkk_requests_user")
  @@map("kvkk_requests")
}

// ── SCORM DENEMELERİ ──
model ScormAttempt {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String    @db.Uuid @map("organization_id")
  userId            String    @db.Uuid @map("user_id")
  trainingId        String    @db.Uuid @map("training_id")
  attemptId         String    @unique @default(uuid()) @db.Uuid @map("attempt_id")
  suspendData       String?   @db.Text @map("suspend_data")
  lessonStatus      String?   @db.VarChar(30) @map("lesson_status")
  score             Float?
  totalTime         String?   @db.VarChar(50) @map("total_time")
  launchData        String?   @db.Text @map("launch_data")
  completionStatus  String?   @db.VarChar(30) @map("completion_status")
  successStatus     String?   @db.VarChar(30) @map("success_status")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  training          Training  @relation(fields: [trainingId], references: [id])
  user              User      @relation(fields: [userId], references: [id])

  @@index([userId, trainingId], map: "idx_scorm_attempts_user_training")
  @@map("scorm_attempts")
}

// ── DEPARTMAN EĞİTİM KURALLARI ──
model DepartmentTrainingRule {
  id             String   @id @default(uuid()) @db.Uuid
  departmentId   String   @db.Uuid @map("department_id")
  trainingId     String   @db.Uuid @map("training_id")
  organizationId String   @db.Uuid @map("organization_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  department     Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  training       Training   @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@unique([departmentId, trainingId])
  @@index([organizationId], map: "idx_dept_training_rules_org")
  @@map("department_training_rules")
}

// ── SMG AKTİVİTELERİ ──
model SmgActivity {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid @map("user_id")
  organizationId String    @db.Uuid @map("organization_id")
  activityType   String    @db.VarChar(50) @map("activity_type")
  // COURSE_COMPLETION | EXTERNAL_TRAINING | CONFERENCE | PUBLICATION
  title          String    @db.VarChar(255)
  provider       String?   @db.VarChar(255)
  completionDate DateTime  @map("completion_date") @db.Date
  smgPoints      Int       @map("smg_points")
  certificateUrl String?   @db.VarChar(1000) @map("certificate_url")
  approvalStatus String    @default("PENDING") @db.VarChar(20) @map("approval_status")
  // PENDING | APPROVED | REJECTED
  approvedBy     String?   @db.Uuid @map("approved_by")
  approvedAt     DateTime? @map("approved_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user           User         @relation("UserSmgActivities", fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approver       User?        @relation("SmgApprovals", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([userId], map: "idx_smg_activities_user")
  @@index([organizationId], map: "idx_smg_activities_org")
  @@map("smg_activities")
}

// ── SMG DÖNEMLERİ ──
model SmgPeriod {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid @map("organization_id")
  name           String   @db.VarChar(255)
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  requiredPoints Int      @map("required_points")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "idx_smg_periods_org")
  @@map("smg_periods")
}

// ── İÇERİK KÜTÜPHANESİ ──
model ContentLibrary {
  id           String   @id @default(uuid()) @db.Uuid
  title        String   @db.VarChar(500)
  description  String?  @db.Text
  category     String   @db.VarChar(50)
  // INFECTION_CONTROL | FIRE_SAFETY | PATIENT_RIGHTS | KVKK |
  // OCCUPATIONAL_HEALTH | FIRST_AID | MEDICAL_WASTE | HAND_HYGIENE |
  // WORKPLACE_VIOLENCE | EMERGENCY_PROCEDURES
  thumbnailUrl String?  @db.Text @map("thumbnail_url")
  duration     Int      // dakika
  smgPoints    Int      @default(0) @map("smg_points")
  difficulty   String   @db.VarChar(20) // BASIC | INTERMEDIATE | ADVANCED
  targetRoles  Json     @map("target_roles") // ["doctor","nurse","all"]
  isActive     Boolean  @default(true) @map("is_active")
  createdById  String?  @db.Uuid @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  createdBy User?                      @relation("ContentLibraryCreator", fields: [createdById], references: [id])
  installs  OrganizationContentLibrary[]
  trainings Training[]                 @relation("TrainingFromLibrary")

  @@index([category], map: "idx_content_library_category")
  @@map("content_library")
}

// ── KURUM İÇERİK KÜTÜPHANESİ (kurulum takibi) ──
model OrganizationContentLibrary {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @db.Uuid @map("organization_id")
  contentLibraryId String   @db.Uuid @map("content_library_id")
  installedAt      DateTime @default(now()) @map("installed_at") @db.Timestamptz
  installedBy      String?  @db.Uuid @map("installed_by")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentLibrary ContentLibrary @relation(fields: [contentLibraryId], references: [id], onDelete: Cascade)
  installer      User?          @relation("ContentLibraryInstaller", fields: [installedBy], references: [id])

  @@unique([organizationId, contentLibraryId])
  @@index([organizationId], map: "idx_org_content_library_org")
  @@map("organization_content_library")
}

// ── HIS ENTEGRASYONU ──
model HisIntegration {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid @map("organization_id")
  name           String    @db.VarChar(255)
  baseUrl        String    @db.VarChar(500) @map("base_url")
  authType       String    @db.VarChar(20) @map("auth_type")
  credentials    Json
  isActive       Boolean   @default(true) @map("is_active")
  lastSyncAt     DateTime? @map("last_sync_at") @db.Timestamptz
  syncInterval   Int       @default(60) @map("sync_interval")
  fieldMapping   Json      @default("{}") @map("field_mapping")
  webhookToken   String    @unique @db.VarChar(128) @map("webhook_token")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncLogs       SyncLog[]

  @@index([organizationId], map: "idx_his_integrations_org")
  @@index([isActive], map: "idx_his_integrations_active")
  @@map("his_integrations")
}

// ── SENKRONIZASYON LOGLARI ──
model SyncLog {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @db.Uuid @map("organization_id")
  integrationId    String    @db.Uuid @map("integration_id")
  syncType         String    @db.VarChar(30) @map("sync_type")
  status           String    @default("RUNNING") @db.VarChar(20)
  totalRecords     Int       @default(0) @map("total_records")
  processedRecords Int       @default(0) @map("processed_records")
  errors           Json      @default("[]")
  startedAt        DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt      DateTime? @map("completed_at") @db.Timestamptz

  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration      HisIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "idx_sync_logs_org")
  @@index([integrationId], map: "idx_sync_logs_integration")
  @@index([status], map: "idx_sync_logs_status")
  @@map("sync_logs")
}

// ── 360° YETKİNLİK DEĞERLENDİRME ──

model CompetencyForm {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid @map("organization_id")
  title          String    @db.VarChar(255)
  description    String?   @db.Text
  targetRole     String?   @db.VarChar(100) @map("target_role")
  periodStart    DateTime  @map("period_start") @db.Date
  periodEnd      DateTime  @map("period_end") @db.Date
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  categories     CompetencyCategory[]
  evaluations    CompetencyEvaluation[]

  @@index([organizationId], map: "idx_comp_forms_org")
  @@map("competency_forms")
}

model CompetencyCategory {
  id      String  @id @default(uuid()) @db.Uuid
  formId  String  @db.Uuid @map("form_id")
  name    String  @db.VarChar(255)
  weight  Int     @default(0)
  order   Int     @default(0)

  form    CompetencyForm   @relation(fields: [formId], references: [id], onDelete: Cascade)
  items   CompetencyItem[]

  @@index([formId], map: "idx_comp_categories_form")
  @@map("competency_categories")
}

model CompetencyItem {
  id           String  @id @default(uuid()) @db.Uuid
  categoryId   String  @db.Uuid @map("category_id")
  text         String  @db.VarChar(500)
  description  String? @db.Text
  order        Int     @default(0)

  category CompetencyCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  answers  CompetencyAnswer[]

  @@index([categoryId], map: "idx_comp_items_category")
  @@map("competency_items")
}

model CompetencyEvaluation {
  id             String    @id @default(uuid()) @db.Uuid
  formId         String    @db.Uuid @map("form_id")
  subjectId      String    @db.Uuid @map("subject_id")
  evaluatorId    String    @db.Uuid @map("evaluator_id")
  evaluatorType  String    @db.VarChar(20) @map("evaluator_type")
  // SELF | MANAGER | PEER | SUBORDINATE
  status         String    @default("PENDING") @db.VarChar(20)
  // PENDING | COMPLETED
  overallScore   Decimal?  @db.Decimal(4, 2) @map("overall_score")
  completedAt    DateTime? @map("completed_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  form      CompetencyForm      @relation(fields: [formId], references: [id], onDelete: Cascade)
  subject   User                @relation("EvaluationSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  evaluator User                @relation("EvaluationEvaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)
  answers   CompetencyAnswer[]

  @@unique([formId, subjectId, evaluatorId])
  @@index([subjectId], map: "idx_comp_evals_subject")
  @@index([evaluatorId], map: "idx_comp_evals_evaluator")
  @@index([formId], map: "idx_comp_evals_form")
  @@map("competency_evaluations")
}

model CompetencyAnswer {
  id           String  @id @default(uuid()) @db.Uuid
  evaluationId String  @db.Uuid @map("evaluation_id")
  itemId       String  @db.Uuid @map("item_id")
  score        Int
  comment      String? @db.Text

  evaluation CompetencyEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  item       CompetencyItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, itemId])
  @@index([evaluationId], map: "idx_comp_answers_eval")
  @@map("competency_answers")
}

// ── WEB PUSH ABONELİKLERİ ──
model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId], map: "idx_push_subscriptions_user")
  @@map("push_subscriptions")
}
