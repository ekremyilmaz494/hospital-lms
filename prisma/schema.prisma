  text           String   @db.Text
  category       String   @db.VarChar(100)
  difficulty     String   @default("medium") @db.VarChar(10)
  tags           String[]
  points         Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization         @relation(fields: [organizationId], references: [id])
  options      QuestionBankOption[]

  @@index([organizationId], map: "idx_question_bank_org")
  @@map("question_bank")
}

model QuestionBankOption {
  id             String  @id @default(uuid()) @db.Uuid
  questionBankId String  @map("question_bank_id") @db.Uuid
  text           String  @db.Text
  isCorrect      Boolean @map("is_correct")
  order          Int

  question QuestionBank @relation(fields: [questionBankId], references: [id], onDelete: Cascade)

  @@map("question_bank_options")
}

// ── AI İÇERİK STÜDYOSU v2 ──

model AiNotebook {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  notebookLmId   String   @map("notebooklm_id") @db.VarChar(100)
  title          String   @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization       @relation(fields: [organizationId], references: [id])
  sources      AiNotebookSource[]
  generations  AiGeneration[]

  @@index([organizationId])
  @@map("ai_notebooks")
}

model AiNotebookSource {
  id         String   @id @default(uuid()) @db.Uuid
  notebookId String   @map("notebook_id") @db.Uuid
  sourceLmId String?  @map("source_lm_id") @db.VarChar(100)
  fileName   String   @map("file_name") @db.VarChar(500)
  fileType   String   @map("file_type") @db.VarChar(50)
  fileSize   Int      @map("file_size")
  s3Key      String?  @map("s3_key") @db.Text
  sourceType String   @map("source_type") @db.VarChar(30)
  sourceUrl  String?  @map("source_url") @db.Text
  status     String   @default("uploading") @db.VarChar(30)
  summary    String?  @db.Text
  keyTopics  Json?    @map("key_topics")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  notebook AiNotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([notebookId])
  @@map("ai_notebook_sources")
}

model AiGeneration {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  notebookId       String    @map("notebook_id") @db.Uuid
  title            String    @db.VarChar(500)
  artifactType     String    @map("artifact_type") @db.VarChar(30)
  artifactLmId     String?   @map("artifact_lm_id") @db.VarChar(100)
  taskLmId         String?   @map("task_lm_id") @db.VarChar(100)
  instructions     String?   @db.Text
  settings         Json      @default("{}")
  status           String    @default("pending") @db.VarChar(30)
  progress         Int       @default(0)
  outputS3Key      String?   @map("output_s3_key") @db.Text
  outputFileType   String?   @map("output_file_type") @db.VarChar(20)
  outputSize       Int?      @map("output_size")
  transcript       String?   @db.Text
  contentData      Json?     @map("content_data")
  metadata         Json      @default("{}")
  errorMessage     String?   @map("error_message") @db.Text
  evaluation       String?   @db.VarChar(20)
  evaluationNote   String?   @map("evaluation_note") @db.Text
  evaluatedAt      DateTime? @map("evaluated_at") @db.Timestamptz
  evaluatedById    String?   @map("evaluated_by_id") @db.Uuid
  savedToLibrary   Boolean   @default(false) @map("saved_to_library")
  contentLibraryId String?   @map("content_library_id") @db.Uuid
  savedAt          DateTime? @map("saved_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization    @relation(fields: [organizationId], references: [id])
  user           User            @relation("UserAiGenerations", fields: [userId], references: [id])
  notebook       AiNotebook      @relation(fields: [notebookId], references: [id])
  evaluatedBy    User?           @relation("AiEvaluator", fields: [evaluatedById], references: [id])
  contentLibrary ContentLibrary? @relation("AiToLibrary", fields: [contentLibraryId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([artifactType])
  @@index([evaluation])
  @@map("ai_generations")
}

model AiGoogleConnection {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @unique @map("organization_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  email           String
  status          String    @default("pending")
  encryptedCookie String?   @map("encrypted_cookie") @db.Text
  lastVerifiedAt  DateTime? @map("last_verified_at") @db.Timestamptz
  lastUsedAt      DateTime? @map("last_used_at") @db.Timestamptz
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz
  errorMessage    String?   @map("error_message")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([status])
  @@map("ai_google_connections")
}

// ──────────────────────────────────────────────────────────────
// EY.FR.40 EĞİTİM DEĞERLENDİRME (GERİ BİLDİRİM) FORMU
// Her organizasyon için tek form; kategoriler + item'lar dinamik.
// Eğitim/sınav akışı sonunda (geçsin/kalsın) personele gösterilir.
// ──────────────────────────────────────────────────────────────

model TrainingFeedbackForm {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @unique @map("organization_id") @db.Uuid
  title          String   @default("Eğitim Değerlendirme Anket Formu") @db.VarChar(255)
  description    String?  @db.Text
  documentCode   String?  @default("EY.FR.40") @map("document_code") @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  categories   TrainingFeedbackCategory[]
  responses    TrainingFeedbackResponse[]

  @@map("training_feedback_forms")
}

model TrainingFeedbackCategory {
  id     String @id @default(uuid()) @db.Uuid
  formId String @map("form_id") @db.Uuid
  name   String @db.VarChar(255)
  order  Int    @default(0)

  form  TrainingFeedbackForm   @relation(fields: [formId], references: [id], onDelete: Cascade)
  items TrainingFeedbackItem[]

  @@index([formId], map: "idx_tfb_categories_form")
  @@map("training_feedback_categories")
}

model TrainingFeedbackItem {
  id           String  @id @default(uuid()) @db.Uuid
  categoryId   String  @map("category_id") @db.Uuid
  text         String  @db.VarChar(500)
  // likert_5 (1-5) | yes_partial_no (1=Evet, 2=Kısmen, 3=Hayır) | text (serbest metin)
  questionType String  @default("likert_5") @map("question_type") @db.VarChar(20)
  isRequired   Boolean @default(true) @map("is_required")
  order        Int     @default(0)

  category TrainingFeedbackCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  answers  TrainingFeedbackAnswer[]

  @@index([categoryId], map: "idx_tfb_items_category")
  @@map("training_feedback_items")
}

model TrainingFeedbackResponse {
  id             String   @id @default(uuid()) @db.Uuid
  formId         String   @map("form_id") @db.Uuid
  attemptId      String   @unique @map("attempt_id") @db.Uuid
  trainingId     String   @map("training_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  includeName    Boolean  @default(false) @map("include_name")
  isPassed       Boolean  @map("is_passed")
  submittedAt    DateTime @default(now()) @map("submitted_at") @db.Timestamptz

  form         TrainingFeedbackForm     @relation(fields: [formId], references: [id], onDelete: Restrict)
  attempt      ExamAttempt              @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  training     Training                 @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  answers      TrainingFeedbackAnswer[]

  @@index([organizationId, trainingId], map: "idx_tfb_responses_org_training")
  @@index([organizationId, submittedAt], map: "idx_tfb_responses_org_submitted")
  @@map("training_feedback_responses")
}

model TrainingFeedbackAnswer {
  id         String  @id @default(uuid()) @db.Uuid
  responseId String  @map("response_id") @db.Uuid
  itemId     String  @map("item_id") @db.Uuid
  score      Int?
  textAnswer String? @map("text_answer") @db.Text

  response TrainingFeedbackResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  item     TrainingFeedbackItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([responseId, itemId])
  @@index([responseId], map: "idx_tfb_answers_response")
  @@map("training_feedback_answers")
}
