# AI İçerik Stüdyosu — Python Servis Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.

# Next.js ile paylaşılan gizli anahtar (openssl rand -hex 32 ile üretin)
INTERNAL_API_KEY=rastgele_uzun_gizli_anahtar_buraya

# NotebookLM kimlik doğrulama (base64 encoded JSON)
# python -m notebooklm login → auth dosyasını base64 encode edin
NOTEBOOKLM_AUTH_JSON=

# NotebookLM cookie dosyası yolu
NOTEBOOKLM_COOKIE_PATH=./auth/cookies.json

# Servis portu
PORT=8100

# Geçici dosya klasörü
TEMP_DIR=./temp

# Maksimum üretim zaman aşımı (saniye)
MAX_GENERATION_TIMEOUT=300
