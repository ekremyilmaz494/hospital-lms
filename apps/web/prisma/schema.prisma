// `organizationId` NULL ise: global (resmi JCI/ISO/TJC/OSHA standartları —
// seed ile yüklenir, admin düzenleyemez).
// `organizationId` dolu ise: o hastaneye özel ek standart — hospital admin
// kendisi oluşturur/düzenler/siler.
//
// Uniqueness: (code, organization_id) — aynı kod birden fazla hastanede
// kullanılabilir ama bir hastane içinde tekil.
model AccreditationStandard {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                       String   @db.VarChar(50)
  title                      String   @db.VarChar(500)
  description                String?  @db.Text
  standardBody               String   @map("standard_body") @db.VarChar(20)
  requiredTrainingCategories Json     @default("[]") @map("required_training_categories")
  requiredCompletionRate     Int      @default(80) @map("required_completion_rate")
  isActive                   Boolean  @default(true) @map("is_active")
  organizationId             String?  @map("organization_id") @db.Uuid
  createdById                String?  @map("created_by") @db.Uuid
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization? @relation("OrgAccreditationStandards", fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("AccreditationStandardCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([code, organizationId], map: "uq_accreditation_standards_code_org")
  @@index([standardBody], map: "idx_accreditation_standards_body")
  @@index([organizationId], map: "idx_accreditation_standards_org")
  @@map("accreditation_standards")
}

// ── AKREDİTASYON RAPORLARI ──
model AccreditationReport {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        String   @map("organization_id") @db.Uuid
  title                 String   @db.VarChar(500)
  standardBody          String   @map("standard_body") @db.VarChar(20)
  generatedAt           DateTime @default(now()) @map("generated_at") @db.Timestamptz
  generatedBy           String   @map("generated_by") @db.Uuid
  periodStart           DateTime @map("period_start") @db.Timestamptz
  periodEnd             DateTime @map("period_end") @db.Timestamptz
  overallComplianceRate Decimal  @default(0) @map("overall_compliance_rate") @db.Decimal(5, 2)
  findings              Json     @default("[]")
  reportUrl             String?  @map("report_url") @db.Text
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generatedByUser User         @relation(fields: [generatedBy], references: [id], onDelete: Restrict)

  @@index([organizationId], map: "idx_accreditation_reports_org")
  @@index([standardBody], map: "idx_accreditation_reports_body")
  @@index([generatedAt], map: "idx_accreditation_reports_date")
  @@map("accreditation_reports")
}

// ── EĞİTİM KATEGORİLERİ ──
model TrainingCategory {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  value          String   @db.VarChar(100)
  label          String   @db.VarChar(100)
  icon           String   @db.VarChar(30)
  color          String?  @db.VarChar(9)
  order          Int      @default(0)
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, value])
  @@index([organizationId, order], map: "idx_training_categories_org_order")
  @@map("training_categories")
}

// ── SORU BANKASI ──
model QuestionBank {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  text           String   @db.Text
  category       String   @db.VarChar(100)
  difficulty     String   @default("medium") @db.VarChar(10)
  tags           String[]
  points         Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization         @relation(fields: [organizationId], references: [id])
  options      QuestionBankOption[]

  @@index([organizationId], map: "idx_question_bank_org")
  @@map("question_bank")
}

model QuestionBankOption {
  id             String   @id @default(uuid()) @db.Uuid
  questionBankId String   @map("question_bank_id") @db.Uuid
  text           String   @db.Text
  isCorrect      Boolean  @map("is_correct")
  order          Int
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  question QuestionBank @relation(fields: [questionBankId], references: [id], onDelete: Cascade)

  @@map("question_bank_options")
}

// ──────────────────────────────────────────────────────────────
// EY.FR.40 EĞİTİM DEĞERLENDİRME (GERİ BİLDİRİM) FORMU
// Her organizasyon birden çok form taslağı tutabilir; bir anda yalnızca biri
// aktif olur. Aktif tek-form kuralı DB seviyesinde partial unique index ile
// garantilenir (migration SQL'inde elle eklenmiştir, prisma diff bunu üretmez).
// Eğitim/sınav akışı sonunda (geçsin/kalsın) personele aktif form gösterilir.
// ──────────────────────────────────────────────────────────────

model TrainingFeedbackForm {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  title          String    @default("Eğitim Değerlendirme Anket Formu") @db.VarChar(255)
  description    String?   @db.Text
  documentCode   String?   @default("EY.FR.40") @map("document_code") @db.VarChar(50)
  isActive       Boolean   @default(false) @map("is_active")
  // Bu form aktive edildiğinde tüm eğitimlerde feedback zorunluluğunu nasıl
  // ayarlayacağı: true → tüm Training.feedbackMandatory=true (sertifika gating
  // çalışır), false → tüm Training.feedbackMandatory=false (form opsiyonel).
  isMandatory    Boolean   @default(true) @map("is_mandatory")
  // Yanıt verilmiş ama artık kullanılmayan formlar arşive alınır — silmek
  // istenir ama yanıt geçmişi (FK: TrainingFeedbackResponse.formId) korunur.
  // Liste UI'sı default arşivsizleri gösterir.
  isArchived     Boolean   @default(false) @map("is_archived")
  // PDF header'da gösterilen sabit doküman metadata'sı.
  // Form snapshot'a otomatik kopyalanır → submit anındaki değerler korunur.
  publishedAt    DateTime? @map("published_at") @db.Timestamptz
  revisionNumber Int       @default(0) @map("revision_number")
  revisionDate   DateTime? @map("revision_date") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  categories   TrainingFeedbackCategory[]
  responses    TrainingFeedbackResponse[]

  @@index([organizationId], map: "idx_feedback_forms_org")
  @@index([organizationId, updatedAt(sort: Desc)], map: "idx_feedback_forms_org_updated")
  @@index([organizationId, isArchived], map: "idx_feedback_forms_org_archive")
  @@map("training_feedback_forms")
}

model TrainingFeedbackCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  formId    String   @map("form_id") @db.Uuid
  name      String   @db.VarChar(255)
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  form  TrainingFeedbackForm   @relation(fields: [formId], references: [id], onDelete: Cascade)
  items TrainingFeedbackItem[]

  @@index([formId], map: "idx_tfb_categories_form")
  @@map("training_feedback_categories")
}

model TrainingFeedbackItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId   String   @map("category_id") @db.Uuid
  text         String   @db.VarChar(500)
  // likert_5 (1-5) | yes_partial_no (1=Evet, 2=Kısmen, 3=Hayır) | text (serbest metin)
  questionType String   @default("likert_5") @map("question_type") @db.VarChar(20)
  isRequired   Boolean  @default(true) @map("is_required")
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  category TrainingFeedbackCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  answers  TrainingFeedbackAnswer[]

  @@index([categoryId], map: "idx_tfb_items_category")
  @@map("training_feedback_items")
}

model TrainingFeedbackResponse {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  formId         String   @map("form_id") @db.Uuid
  attemptId      String   @unique @map("attempt_id") @db.Uuid
  trainingId     String   @map("training_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  includeName    Boolean  @default(false) @map("include_name")
  isPassed       Boolean  @map("is_passed")
  submittedAt    DateTime @default(now()) @map("submitted_at") @db.Timestamptz
  // Submit anındaki form yapısının donmuş kopyası (categories + items).
  // Admin sonradan form'u düzenlese bile detay sayfası geçmişi korur.
  formSnapshot   Json?    @map("form_snapshot") @db.JsonB
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  form         TrainingFeedbackForm     @relation(fields: [formId], references: [id], onDelete: Restrict)
  attempt      ExamAttempt              @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  training     Training                 @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  answers      TrainingFeedbackAnswer[]

  @@index([organizationId, trainingId], map: "idx_tfb_responses_org_training")
  @@index([organizationId, submittedAt], map: "idx_tfb_responses_org_submitted")
  @@map("training_feedback_responses")
}

model TrainingFeedbackAnswer {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  responseId   String   @map("response_id") @db.Uuid
  // Item silinse bile cevap korunur (SetNull). Analytics ve detay sayfası
  // itemSnapshot'tan okur — tarihsel bütünlük bozulmaz.
  itemId       String?  @map("item_id") @db.Uuid
  // Cevap verildiği andaki item metadata (text, questionType, categoryName).
  itemSnapshot Json?    @map("item_snapshot") @db.JsonB
  score        Int?
  textAnswer   String?  @map("text_answer") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  response TrainingFeedbackResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  item     TrainingFeedbackItem?    @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@unique([responseId, itemId])
  @@index([responseId], map: "idx_tfb_answers_response")
  @@map("training_feedback_answers")
}

// ── GÜVENİLİR CİHAZLAR (SMS MFA) ──
// Kullanıcı SMS doğrulaması sonrası cihazı "güvenilir" olarak işaretlenir.
// 7 gün boyunca aynı cihazdan login'de SMS tekrar istenmez.
// token_hash sadece hash olarak saklanır — plaintext token cookie'de yaşar.
model TrustedDevice {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(128)
  userAgent  String?   @map("user_agent") @db.Text
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  lastUsedAt DateTime  @default(now()) @map("last_used_at") @db.Timestamptz
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_trusted_devices_user")
  @@index([expiresAt], map: "idx_trusted_devices_expires")
  @@map("trusted_devices")
}

// ── DAVET TOKEN'LARI (link tabanlı hesap aktivasyonu) ──
// Slack/Linear/Notion pattern: davet anında auth user yaratılmaz, sadece token kaydedilir.
// Davet edilen kişi linke tıkladığında kendi şifresini kurar ve kabul eder.
// Plaintext token sadece URL/email'de bulunur, DB'de SHA-256 hash saklanır.
model Invitation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash       String    @unique @map("token_hash") @db.VarChar(64)
  email           String    @db.VarChar(255)
  firstName       String    @map("first_name") @db.VarChar(100)
  lastName        String    @map("last_name") @db.VarChar(100)
  phone           String?   @db.VarChar(50)
  title           String?   @db.VarChar(100)
  role            String    @db.VarChar(20)
  organizationId  String    @map("organization_id") @db.Uuid
  departmentId    String?   @map("department_id") @db.Uuid
  invitedByUserId String?   @map("invited_by_user_id") @db.Uuid
  setAsOwner      Boolean   @default(false) @map("set_as_owner")
  // TC Kimlik No — davet anında alınır, kabul edildiğinde User tablosuna kopyalanır.
  // KVKK: AES-256-GCM ciphertext + HMAC-SHA256 hash. Plaintext sadece davet sırasında
  // network'te yer alır, sonra atılır. ENCRYPTION_KEY ile şifrelenir.
  tcEncrypted     String?   @map("tc_encrypted") @db.Text
  tcHash          String?   @map("tc_hash") @db.VarChar(64)
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz
  acceptedAt      DateTime? @map("accepted_at") @db.Timestamptz
  acceptedUserId  String?   @map("accepted_user_id") @db.Uuid
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz
  attemptCount    Int       @default(0) @map("attempt_count")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  invitedBy    User?        @relation("InvitationsInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  acceptedUser User?        @relation("InvitationsAcceptedBy", fields: [acceptedUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, acceptedAt, revokedAt], map: "idx_invitations_org_status")
  @@index([expiresAt], map: "idx_invitations_expires")
  @@index([email, organizationId], map: "idx_invitations_email_org")
  @@map("invitations")
}

// ══════════════════════════════════════════════════════════════════════════
// OYUNLAŞTIRMA — Faz 1: Günün Soruları (spaced-repetition / Leitner)
// SMG (mesleki gelişim / onay) sisteminden TAMAMEN AYRIDIR. Karıştırma.
// ══════════════════════════════════════════════════════════════════════════

// Personel başına Leitner spaced-repetition durumu. Kutu 0..5, due seçimi
// nextReviewAt üstünden yapılır. Havuza yalnız GEÇİLEN eğitimlerin soruları girer.
model DailyReview {
  userId         String    @map("user_id") @db.Uuid
  questionId     String    @map("question_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  box            Int       @default(0) // 0..5
  nextReviewAt   DateTime  @map("next_review_at") @db.Timestamptz
  lastResult     Boolean?  @map("last_result")
  lastReviewedAt DateTime? @map("last_reviewed_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([userId, questionId])
  @@index([userId, nextReviewAt], map: "idx_daily_review_user_due")
  @@index([organizationId], map: "idx_daily_review_org")
  @@map("daily_reviews")
}

// /daily/submit idempotency + replay snapshot + Faz 1 puan kaydı.
// submissionId = client-uuid (dedup anahtarı). Aynı submissionId tekrar gelirse
// kredi BİR kez verilir, snapshot'tan birebir aynı sonuç döner.
model DailySubmission {
  submissionId   String   @id @map("submission_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  correctCount   Int      @map("correct_count")
  pointsAwarded  Int      @map("points_awarded")
  resultsJson    Json     @map("results_json") // [{ questionId, correct, newBox, nextReviewAt }]
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_daily_submission_user")
  @@map("daily_submissions")
}

// ══════════════════════════════════════════════════════════════════════════
// OYUNLAŞTIRMA — Faz 2: Puan / Streak / Rozet. SMG'den TAMAMEN AYRIDIR.
// ══════════════════════════════════════════════════════════════════════════

// Append-only puan defteri. Toplam puan = SUM(points). dedupKey ile idempotency
// (daily_review:<submissionId>, exam_pass:<eventId> ...). points asla negatif olmaz.
model PointLedger {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  eventType      String   @map("event_type") @db.VarChar(30) // daily_review | exam_pass | training_complete | feedback_submit
  refId          String?  @map("ref_id") @db.Uuid            // submissionId / attemptId / assignmentId / responseId
  points         Int                                          // >= 0 (monoton artan)
  dedupKey       String   @unique @map("dedup_key") @db.VarChar(120)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_point_ledger_user")
  @@index([userId, eventType], map: "idx_point_ledger_user_event")
  @@index([organizationId], map: "idx_point_ledger_org")
  @@map("point_ledger")
}

// Kullanıcı başına günlük seri. Server-clock (Europe/Istanbul). lastActiveDate
// günlük review submit'inde ilerletilir; gece cron freeze/reset uygular.
model UserStreak {
  userId         String    @id @map("user_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  current        Int       @default(0)
  longest        Int       @default(0)
  lastActiveDate DateTime? @map("last_active_date") @db.Date
  freezesLeft    Int       @default(2) @map("freezes_left")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "idx_user_streak_org")
  @@map("user_streaks")
}

// Rozet katalog — GLOBAL seed (organizationId YOK). thresholdJson kazanım koşulu.
model Badge {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.VarChar(40)
  tier          String   @db.VarChar(10) // bronze | silver | gold
  icon          String   @db.VarChar(40) // izinli mobil ikon seti
  title         String   @db.VarChar(120)
  thresholdJson Json     @map("threshold_json") // { type, value, eventType? }
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")

  userBadges UserBadge[]

  @@map("badges")
}

// Kazanılan rozet. PK [userId, badgeId] → idempotent earn (skipDuplicates).
model UserBadge {
  userId         String   @map("user_id") @db.Uuid
  badgeId        String   @map("badge_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  earnedAt       DateTime @default(now()) @map("earned_at") @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@index([userId], map: "idx_user_badge_user")
  @@index([organizationId], map: "idx_user_badge_org")
  @@map("user_badges")
}

// ═══════════════ Lisans (On-Premise) ═══════════════

// Platform lisansı — ON-PREM kurulumun tek (singleton, id=1) lisans kaydı.
// licenseJwt/receiptJwt her okunuşta İMZA DOĞRULAMASINDAN geçer (store.ts):
// satır elle değiştirilirse imza düşer → NO_LICENSE. Bulut deploy'unda tablo
// boş durur, zararsızdır. clockWatermark = görülen en ileri zaman (saat
// geri alma tespiti; makbuz iat'i ile ileri sarar).
model PlatformLicense {
  id                  Int       @id @default(1)
  licenseJwt          String    @map("license_jwt") @db.Text
  licenseId           String    @map("license_id") @db.VarChar(64)
  instanceId          String    @map("instance_id") @db.Uuid
  receiptJwt          String?   @map("receipt_jwt") @db.Text
  lastHeartbeatAt     DateTime? @map("last_heartbeat_at") @db.Timestamptz
  lastHeartbeatStatus String?   @map("last_heartbeat_status") @db.VarChar(20)
  clockWatermark      DateTime  @map("clock_watermark") @db.Timestamptz
  activatedAt         DateTime  @default(now()) @map("activated_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("platform_license")
}

// Klinovax lisans sunucusu (SaaS tarafı) — on-prem kurulumlara kesilen
// lisansların kaydı, iptali ve heartbeat telemetrisi. On-prem kurulumda bu üç
// tablo boş durur (zararsız). License.id == lisans JWT'sinin jti claim'i.
model License {
  id               String    @id @db.Uuid
  customerName     String    @map("customer_name") @db.VarChar(200)
  contactEmail     String?   @map("contact_email") @db.VarChar(200)
  // Kayıtlı ham lisans JWT'si — yeniden indirme + heartbeat'te renewedLicense
  // olarak sunma (elle dosya değişmeden yenileme) için saklanır.
  licenseJwt       String    @map("license_jwt") @db.Text
  schemaVersion    Int       @default(1) @map("schema_version")
  licenseType      String    @default("standard") @map("license_type") @db.VarChar(20)
  maxOrganizations Int?      @map("max_organizations")
  maxStaff         Int?      @map("max_staff")
  graceDays        Int       @default(14) @map("grace_days")
  validUntil       DateTime? @map("valid_until") @db.Timestamptz
  status           String    @default("active") @db.VarChar(20) // active | revoked
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  revokeReason     String?   @map("revoke_reason") @db.Text
  notes            String?   @db.Text
  createdBy        String?   @map("created_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  activations LicenseActivation[]
  heartbeats  LicenseHeartbeat[]

  @@map("licenses")
}

// Bir lisansın aktive edildiği kurulumlar. Aynı lisansın >1 instance'tan
// düzenli heartbeat'i = paylaşım/kopyalama anomalisi (super-admin bildirimi).
model LicenseActivation {
  id          String   @id @default(uuid()) @db.Uuid
  licenseId   String   @map("license_id") @db.Uuid
  instanceId  String   @map("instance_id") @db.Uuid
  appVersion  String?  @map("app_version") @db.VarChar(40)
  hostname    String?  @db.VarChar(200)
  firstSeenAt DateTime @default(now()) @map("first_seen_at") @db.Timestamptz
  lastSeenAt  DateTime @default(now()) @map("last_seen_at") @db.Timestamptz

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, instanceId])
  @@map("license_activations")
}

// Heartbeat telemetrisi — kullanım anlık görüntüsü (org/personel sayısı, sürüm).
// Lisans limit aşımı ve sağlık takibi super-admin panelinde buradan okunur.
model LicenseHeartbeat {
  id         String   @id @default(uuid()) @db.Uuid
  licenseId  String   @map("license_id") @db.Uuid
  instanceId String   @map("instance_id") @db.Uuid
  orgCount   Int      @map("org_count")
  staffCount Int      @map("staff_count")
  appVersion String?  @map("app_version") @db.VarChar(40)
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([licenseId, receivedAt], map: "idx_license_heartbeat_license_time")
  @@map("license_heartbeats")
}

// ═══════════════ İK/HBYS Personel Senkron Entegrasyonu ═══════════════
// Hastanenin kendi İK/HBYS sisteminden otomatik personel ekleme/güncelleme/
// deaktivasyon. Kanal-bağımsız: tek ingestion çekirdeği (src/lib/integration/)
// + 3 adaptör (inbound push API, dosya, zamanlanmış pull). Eski his_integrations
// (2026-03 eklendi, 2026-06 kaldırıldı) yerine geçer — farkları: API-key servis
// auth, idempotency, dry-run, satır-bazlı sonuç, güvenli deaktivasyon eşiği.

// Veri akış kanalı
enum IntegrationChannel {
  push // hastane sistemi bizim API'mizi çağırır
  file // gecelik export dosyası (xlsx/csv) yüklenir
  pull // biz onların API'sini periyodik sorgularız

  @@map("integration_channel")
}

// Senkron modu: delta = yalnız gönderilen kayıtlar işlenir;
// snapshot = feed TAM liste kabul edilir, feed'de olmayan entegrasyon-yönetimli
// (externalId != null) personel deaktive edilebilir (deactivateMissing + eşik).
enum SyncMode {
  delta
  snapshot

  @@map("sync_mode")
}

// Pull adaptörünün karşı API'ye kimlik doğrulama tipi
enum PullAuthType {
  bearer     // Authorization: Bearer <token>
  basic      // Authorization: Basic base64(user:pass)
  header_key // özel header (örn. X-Api-Key: <key>)

  @@map("pull_auth_type")
}

// Senkron koşusunu ne tetikledi
enum SyncRunTrigger {
  api      // inbound push (hastane sistemi çağırdı)
  file     // dosya yükleme
  schedule // cron pull
  manual   // admin panelinden "şimdi çalıştır"

  @@map("sync_run_trigger")
}

enum SyncRunMode {
  dry_run // yalnız plan çıkar, hiçbir değişiklik uygulanmaz
  apply

  @@map("sync_run_mode")
}

enum SyncRunStatus {
  running
  completed
  completed_with_errors
  failed
  aborted // güvenlik eşiği (toplu deaktivasyon) veya eşzamanlılık kilidi

  @@map("sync_run_status")
}

// Satır bazında ne yapıldı/yapılacaktı
enum SyncRowAction {
  create
  update
  deactivate
  reactivate
  skip     // fark yok
  conflict // TC/e-posta başka org'da — manuel çözüm gerekir
  error

  @@map("sync_row_action")
}

// Org başına kanal yapılandırması. Bir org birden çok kanalı aynı anda
// kullanabilir (örn. gecelik dosya + anlık push) — kanal başına tek kayıt.
model StaffIntegration {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  channel        IntegrationChannel
  isActive       Boolean            @default(true) @map("is_active")
  syncMode       SyncMode           @default(delta) @map("sync_mode")
  // Kaynak alan adı → StaffRecord alanı eşlemesi (normalize.ts uygular).
  // null = kimliksel eşleme (kaynak zaten bizim alan adlarımızı kullanıyor).
  fieldMapping   Json?              @map("field_mapping")
  // Eksik alanlar için varsayılanlar (örn. { "departmentName": "Genel" })
  defaults       Json?
  // snapshot modda feed'de olmayan entegrasyon-yönetimli personeli deaktive et.
  // Eşik: deaktivasyon sayısı max(5, aktif personelin %deactivateThresholdPct'i)
  // aşarsa koşu ABORT edilir (boş/yarım export kazası koruması); yalnız admin
  // manuel tetiği force ile geçebilir.
  deactivateMissing      Boolean @default(false) @map("deactivate_missing")
  deactivateThresholdPct Int     @default(20) @map("deactivate_threshold_pct")
  // ── pull kanalına özgü ──
  pullBaseUrl              String?       @map("pull_base_url") @db.VarChar(500)
  pullAuthType             PullAuthType? @map("pull_auth_type")
  // crypto.encrypt (AES-256-GCM) ile şifreli JSON: { token } | { username, password } | { headerName, key }
  pullCredentialsEncrypted String?       @map("pull_credentials_encrypted") @db.Text
  pullIntervalMinutes      Int?          @map("pull_interval_minutes")
  // Sayfalama stratejisi: { style: 'page'|'offset'|'cursor', pageParam, sizeParam, pageSize, itemsPath, cursorPath? }
  pullPagination           Json?         @map("pull_pagination")
  lastRunAt                DateTime?     @map("last_run_at") @db.Timestamptz
  lastRunStatus            String?       @map("last_run_status") @db.VarChar(30)
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncRuns     SyncRun[]

  @@unique([organizationId, channel], map: "idx_staff_integrations_org_channel")
  @@index([organizationId], map: "idx_staff_integrations_org")
  @@map("staff_integrations")
}

// Org-scoped makine API anahtarı (inbound push + dosya uçları için).
// Düz anahtar YALNIZ üretim anında bir kez gösterilir; DB'de SHA-256 hex hash.
// keyPrefix (örn. "klx_live_a1b2c3") log/UI'da anahtarı ifşa etmeden tanımlar.
// Rotasyon: yeni anahtar üret + eskiyi revoke et (org başına çoklu aktif anahtar serbest).
model IntegrationApiKey {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String    @db.VarChar(100)
  keyPrefix      String    @map("key_prefix") @db.VarChar(20)
  keyHash        String    @unique(map: "idx_integration_api_keys_hash") @map("key_hash") @db.VarChar(64)
  lastUsedAt     DateTime? @map("last_used_at") @db.Timestamptz
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz
  createdById    String?   @map("created_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncRuns     SyncRun[]

  @@index([organizationId], map: "idx_integration_api_keys_org")
  @@map("integration_api_keys")
}

// Bir senkron koşusunun başlığı (dry-run dahil). Satır ayrıntıları SyncRowResult'ta.
model SyncRun {
  id               String            @id @default(uuid()) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  integrationId    String?           @map("integration_id") @db.Uuid
  channel          IntegrationChannel
  trigger          SyncRunTrigger
  mode             SyncRunMode
  syncMode         SyncMode          @map("sync_mode")
  status           SyncRunStatus     @default(running)
  totalRows        Int               @default(0) @map("total_rows")
  createdRows      Int               @default(0) @map("created_rows")
  updatedRows      Int               @default(0) @map("updated_rows")
  deactivatedRows  Int               @default(0) @map("deactivated_rows")
  reactivatedRows  Int               @default(0) @map("reactivated_rows")
  skippedRows      Int               @default(0) @map("skipped_rows")
  failedRows       Int               @default(0) @map("failed_rows")
  // Koşu-seviyesi hata özeti (abort nedeni, karşı API hatası vb.) — Türkçe.
  errorSummary     Json?             @map("error_summary")
  apiKeyId         String?           @map("api_key_id") @db.Uuid
  requestedById    String?           @map("requested_by_id") @db.Uuid
  fileName         String?           @map("file_name") @db.VarChar(255)
  startedAt        DateTime          @default(now()) @map("started_at") @db.Timestamptz
  completedAt      DateTime?         @map("completed_at") @db.Timestamptz

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration  StaffIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  apiKey       IntegrationApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  rowResults   SyncRowResult[]

  @@index([organizationId, startedAt], map: "idx_sync_runs_org_time")
  @@map("sync_runs")
}

// Koşunun satır-bazlı sonucu. payloadMasked KVKK gereği maskeli tutulur
// (pii-mask; TC ASLA yazılmaz) ve cron/cleanup 90 günde imha eder.
model SyncRowResult {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  syncRunId      String        @map("sync_run_id") @db.Uuid
  rowIndex       Int           @map("row_index")
  externalId     String?       @map("external_id") @db.VarChar(100)
  action         SyncRowAction
  userId         String?       @map("user_id") @db.Uuid
  message        String?       @db.Text
  payloadMasked  Json?         @map("payload_masked")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz

  syncRun SyncRun @relation(fields: [syncRunId], references: [id], onDelete: Cascade)

  @@index([syncRunId], map: "idx_sync_row_results_run")
  @@index([organizationId, createdAt], map: "idx_sync_row_results_org_time")
  @@map("sync_row_results")
}
