generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Multi-tenant rol hiyerarşisi.
// app_metadata.role JWT claim'i ile senkron tutulur (auth-user-factory.ts).
// String yerine enum: typo riskini DB seviyesinde keser.
enum UserRole {
  super_admin
  admin
  staff

  @@map("user_role")
}

// Tenant'ın hizmet verdiği sektör. Faz 3 (2026-05-17): String'den enum'a çevrildi.
// healthcare = sağlık (default — geriye dönük uyum, Devakent dahil)
// other      = belirsiz/genel (fallback; bilinmeyen sektörden gelen yeni org'lar)
// Yeni sektör eklemek için: bu enum'a değer ekle + Postgres ALTER TYPE migration.
// Sektör DÜŞÜRME (enum'dan değer çıkarma) destructive ve önerilmez — orphan satır
// kalırsa migration patlar. Orta vade silinmesi gereken sektör 'other' altına merge.
enum Sector {
  healthcare
  manufacturing
  education
  retail
  other

  @@map("sector")
}

// ── ABONELIK PLANLARI ──
model SubscriptionPlan {
  id                     String   @id @default(uuid()) @db.Uuid
  name                   String   @db.VarChar(100)
  slug                   String   @unique @db.VarChar(50)
  description            String?  @db.Text
  maxStaff               Int?     @map("max_staff")
  maxTrainings           Int?     @map("max_trainings")
  maxStorageGb           Int      @default(10) @map("max_storage_gb")
  priceMonthly           Decimal? @map("price_monthly") @db.Decimal(10, 2)
  priceAnnual            Decimal? @map("price_annual") @db.Decimal(10, 2)
  features               Json     @default("[]")
  isActive               Boolean  @default(true) @map("is_active")
  // Feature gates
  hasScormSupport        Boolean  @default(false) @map("has_scorm_support")
  hasAdvancedReports     Boolean  @default(false) @map("has_advanced_reports")
  hasSsoSupport          Boolean  @default(false) @map("has_sso_support")
  hasCompetencyModule    Boolean  @default(false) @map("has_competency_module")
  hasAccreditationModule Boolean  @default(false) @map("has_accreditation_module")
  hasBulkImport          Boolean  @default(false) @map("has_bulk_import")
  hasCustomCertificates  Boolean  @default(false) @map("has_custom_certificates")
  // İK/HBYS personel senkron entegrasyonu (dosya/push/pull) — /api/integration/v1
  hasStaffIntegration    Boolean  @default(false) @map("has_staff_integration")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  subscriptions OrganizationSubscription[]

  @@map("subscription_plans")
}

// ── ORGANİZASYONLAR ──
model Organization {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String    @db.VarChar(255)
  code                String    @unique @db.VarChar(50)
  slug                String?   @unique @map("slug") @db.VarChar(50)
  customDomain        String?   @unique @map("custom_domain") @db.VarChar(255)
  address             String?   @db.Text
  phone               String?   @db.VarChar(20)
  email               String?   @db.VarChar(255)
  logoUrl             String?   @map("logo_url") @db.Text
  brandColor          String    @default("#0F172A") @map("brand_color") @db.VarChar(9)
  secondaryColor      String    @default("#3B82F6") @map("secondary_color") @db.VarChar(9)
  loginBannerUrl      String?   @map("login_banner_url") @db.Text
  isActive            Boolean   @default(true) @map("is_active")
  isSuspended         Boolean   @default(false) @map("is_suspended")
  suspendedReason     String?   @map("suspended_reason") @db.Text
  suspendedAt         DateTime? @map("suspended_at") @db.Timestamptz
  // Demo organizasyonu işareti — "Demo Yönetimi" menüsünden otomatik üretilir.
  // Gerçek müşteri listelerinden/sayımlarından DIŞLANIR; yalnız bu işaretli org'lar silinebilir.
  isDemo              Boolean   @default(false) @map("is_demo")
  sessionTimeout      Int       @default(30) @map("session_timeout")
  defaultPassingScore Int       @default(70) @map("default_passing_score")
  defaultMaxAttempts  Int       @default(3) @map("default_max_attempts")
  defaultExamDuration Int       @default(30) @map("default_exam_duration")
  // SSO / SAML Configuration
  ssoEnabled          Boolean   @default(false) @map("sso_enabled")
  ssoProvider         String?   @map("sso_provider") @db.VarChar(50)
  ssoEmailDomain      String?   @map("sso_email_domain") @db.VarChar(255)
  samlEntryPoint      String?   @map("saml_entry_point") @db.Text
  samlIssuer          String?   @map("saml_issuer") @db.Text
  samlCert            String?   @map("saml_cert") @db.Text
  oidcDiscoveryUrl    String?   @map("oidc_discovery_url") @db.Text
  oidcClientId        String?   @map("oidc_client_id") @db.VarChar(255)
  oidcClientSecret    String?   @map("oidc_client_secret") @db.Text
  ssoAutoProvision    Boolean   @default(true) @map("sso_auto_provision")
  ssoDefaultRole      UserRole  @default(staff) @map("sso_default_role")
  setupCompleted      Boolean   @default(false) @map("setup_completed")
  setupStep           Int       @default(0) @map("setup_step")
  language            String    @default("tr") @map("language") @db.VarChar(5)
  // SMS MFA (Çok Faktörlü Doğrulama — SMS tabanlı)
  smsMfaEnabled       Boolean   @default(false) @map("sms_mfa_enabled")
  smsMfaEnforcedAt    DateTime? @map("sms_mfa_enforced_at") @db.Timestamptz

  // Veri saklama süreleri (KVKK) — cron/cleanup org-bazında okur (yoksa sabit default).
  dataRetentionDays         Int     @default(365) @map("data_retention_days")
  notificationRetentionDays Int     @default(90)  @map("notification_retention_days")
  backupRetentionDays       Int     @default(90)  @map("backup_retention_days")
  // IP allowlist — açıksa middleware yalnız bu CIDR/IP listesinden erişime izin verir.
  ipAllowlistEnabled        Boolean @default(false) @map("ip_allowlist_enabled")
  ipAllowlist               Json    @default("[]")   @map("ip_allowlist")

  // Centralized email (AWS SES klinovax.com) — per-org override sadece display
  // name + reply-to. Şifre/host yok; platform tek IP'den gönderir, deliverability
  // tek tek hastane SMTP'lerinden çok daha iyi.
  emailDisplayName String? @map("email_display_name") @db.VarChar(100)
  emailReplyTo     String? @map("email_reply_to") @db.VarChar(320)
  emailEnabled     Boolean @default(true) @map("email_enabled")

  // Bildirim tercihleri (Ayarlar → Bildirim sekmesi). emailNotifications: org genelinde
  // hatırlatma e-postası gate'i (reminder cron okur). reminderDaysBefore: eğitim deadline'ından
  // kaç gün önce hatırlatma (cron okur; default 3 = mevcut davranış korunur). notifyOnComplete/
  // notifyOnFail: persist edilir; admin'e sınav-olayı bildirimi davranışı ayrı bir iş (henüz yok).
  emailNotifications Boolean @default(true) @map("email_notifications")
  reminderDaysBefore Int     @default(3) @map("reminder_days_before")
  notifyOnComplete   Boolean @default(true) @map("notify_on_complete")
  notifyOnFail       Boolean @default(true) @map("notify_on_fail")

  // Çok-sektörlü SaaS desteği. Faz 1 default'u "healthcare" — Devakent vb.
  // Faz 3 (2026-05-17): String → Sector enum (CAST migration). Default 'healthcare'
  // backward-compat için tutuldu — register form sector picker explicit zorunluyor,
  // ama legacy create() çağrıları kırılmasın diye DB default duruyor.
  sector Sector @default(healthcare) @map("sector")

  // OpenRouter (AI soru üretimi) — org-specific custom API key (encrypted, opsiyonel)
  openrouterApiKeyEncrypted String? @map("openrouter_api_key_encrypted") @db.Text

  // Esas Yönetici (org owner) — yalnız bu user yeni admin davet edebilir.
  // Devir super_admin tarafından yapılır.
  ownerUserId String? @unique @map("owner_user_id") @db.Uuid
  maxAdmins   Int     @default(5) @map("max_admins")

  // Org-bazında personel (seat) limiti — sözleşmeli kişi sayısı. null = plan limitine
  // düş (SubscriptionPlan.maxStaff), o da yoksa sınırsız. Super-admin bunu istediği zaman
  // değiştirebilir (Devakent: 150 kişilik sözleşme). Yeni personel/davet, kullanım
  // (aktif personel + bekleyen davet) bu limite ulaşınca 403 ile reddedilir → müşteri
  // limiti aşınca yeni ücret talep edilir. Enforcement: src/lib/subscription-guard.ts
  maxStaff Int? @map("max_staff")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  ownerUser              User?                        @relation("OrganizationOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  users                  User[]
  departments            Department[]
  trainings              Training[]
  notifications          Notification[]
  auditLogs              AuditLog[]
  dbBackups              DbBackup[]
  subscription           OrganizationSubscription?
  kvkkRequests           KvkkRequest[]
  smgActivities          SmgActivity[]
  smgPeriods             SmgPeriod[]
  smgCategories          SmgCategory[]
  smgTargetsList         SmgTarget[]                  @relation("SmgTargetOrg")
  mediaAssets            MediaAsset[]                 @relation("OrgMediaAssets")
  competencyForms        CompetencyForm[]
  accreditationReports   AccreditationReport[]
  accreditationStandards AccreditationStandard[]      @relation("OrgAccreditationStandards")
  trainingCategories     TrainingCategory[]
  questionBank           QuestionBank[]
  examAttempts           ExamAttempt[]
  certificates           Certificate[]
  trainingAssignments    TrainingAssignment[]
  // EY.FR.40 Eğitim Geri Bildirim — bir org birden çok form taslağı tutar (tek aktif)
  feedbackForms          TrainingFeedbackForm[]
  feedbackResponses      TrainingFeedbackResponse[]
  // Ek deneme hakkı talepleri
  attemptRequests        ExamAttemptRequest[]
  // Eğitim dönemleri (yıllık)
  trainingPeriods        TrainingPeriod[]
  // Davet token kayıtları (link tabanlı yeni hesap aktivasyonu)
  invitations            Invitation[]
  // İK/HBYS personel senkron entegrasyonu
  staffIntegrations      StaffIntegration[]
  integrationApiKeys     IntegrationApiKey[]
  syncRuns               SyncRun[]

  @@index([sector], map: "organization_sector_idx")
  @@index([isDemo], map: "organization_is_demo_idx")
  @@map("organizations")
}

// ── ORGANİZASYON ABONELİKLERİ ──
model OrganizationSubscription {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @unique @map("organization_id") @db.Uuid
  planId         String    @map("plan_id") @db.Uuid
  status         String    @default("trial") @db.VarChar(20)
  billingCycle   String?   @map("billing_cycle") @db.VarChar(10)
  trialEndsAt    DateTime? @map("trial_ends_at") @db.Timestamptz
  startedAt      DateTime  @default(now()) @map("started_at") @db.Timestamptz
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz
  notes          String?   @db.Text
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments     Payment[]
  invoices     Invoice[]

  @@map("organization_subscriptions")
}

// ── ÖDEMELER ──
model Payment {
  id                   String    @id @default(uuid()) @db.Uuid
  subscriptionId       String    @map("subscription_id") @db.Uuid
  organizationId       String    @map("organization_id") @db.Uuid
  amount               Decimal   @db.Decimal(10, 2)
  currency             String    @default("TRY") @db.VarChar(3)
  status               String    @default("pending") @db.VarChar(20)
  paymentMethod        String?   @map("payment_method") @db.VarChar(30)
  iyzicoPaymentId      String?   @map("iyzico_payment_id") @db.VarChar(100)
  iyzicoConversationId String?   @map("iyzico_conversation_id") @db.VarChar(100)
  cardLastFour         String?   @map("card_last_four") @db.VarChar(4)
  cardBrand            String?   @map("card_brand") @db.VarChar(20)
  errorMessage         String?   @map("error_message") @db.Text
  paidAt               DateTime? @map("paid_at") @db.Timestamptz
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  subscription OrganizationSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoice      Invoice?

  @@index([organizationId], map: "idx_payments_org")
  @@index([organizationId, status], map: "idx_payments_org_status")
  @@index([iyzicoPaymentId], map: "idx_payments_iyzico")
  @@map("payments")
}

// ── FATURALAR ──
model Invoice {
  id             String    @id @default(uuid()) @db.Uuid
  paymentId      String    @unique @map("payment_id") @db.Uuid
  subscriptionId String    @map("subscription_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  invoiceNumber  String    @unique @map("invoice_number") @db.VarChar(30)
  status         String    @default("draft") @db.VarChar(20)
  amount         Decimal   @db.Decimal(10, 2)
  taxRate        Float     @default(20) @map("tax_rate")
  taxAmount      Decimal   @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount    Decimal   @map("total_amount") @db.Decimal(10, 2)
  currency       String    @default("TRY") @db.VarChar(3)
  billingName    String    @map("billing_name") @db.VarChar(255)
  companyName    String?   @map("company_name") @db.VarChar(255)
  billingAddress String?   @map("billing_address") @db.Text
  taxNumber      String?   @map("tax_number") @db.VarChar(20)
  taxOffice      String?   @map("tax_office") @db.VarChar(100)
  periodStart    DateTime  @map("period_start") @db.Timestamptz
  periodEnd      DateTime  @map("period_end") @db.Timestamptz
  issuedAt       DateTime  @default(now()) @map("issued_at") @db.Timestamptz
  sentAt         DateTime? @map("sent_at") @db.Timestamptz
  paidAt         DateTime? @map("paid_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  payment      Payment                  @relation(fields: [paymentId], references: [id])
  subscription OrganizationSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([organizationId], map: "idx_invoices_org")
  @@index([invoiceNumber], map: "idx_invoices_number")
  @@index([organizationId, status], map: "idx_invoices_org_status")
  @@map("invoices")
}

// ── DEPARTMANLAR ──
// Max 2 seviye hiyerarşi: parentId set olabilir, ama parent'ın kendi parentId'si null olmalı.
// Bu kural API katmanında (validations + endpoint check) zorlanır; DB cycle önlemez.
model Department {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(100)
  description    String?  @db.Text
  color          String   @default("#0d9668") @db.VarChar(7)
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  parentId       String?  @map("parent_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent        Department?              @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      Department[]             @relation("DepartmentHierarchy")
  users         User[]
  trainingRules DepartmentTrainingRule[]
  invitations   Invitation[]

  // Unique kuralı parent'a göre değişir, Prisma composite + nullable key destekleyemediği için
  // partial unique index'ler raw migration ile tanımlandı:
  //   departments_org_name_root_unique     WHERE parent_id IS NULL  (kök departmanlarda isim org'da unique)
  //   departments_org_name_parent_unique   WHERE parent_id IS NOT NULL  (aynı parent altında alt dep ismi unique)
  // Bu sayede aynı isim farklı parent altında olabilir (ör. BAŞHEKİMLİK > ACİL SERVİS + HEMŞİRELİK > ACİL SERVİS).
  @@index([organizationId, name], map: "idx_departments_org_name")
  @@index([organizationId], map: "idx_departments_org")
  @@index([parentId], map: "idx_departments_parent")
  @@map("departments")
}

// ── KULLANICILAR ──
model User {
  id                       String    @id @db.Uuid
  organizationId           String?   @map("organization_id") @db.Uuid
  email                    String    @unique @db.VarChar(255)
  firstName                String    @map("first_name") @db.VarChar(100)
  lastName                 String    @map("last_name") @db.VarChar(100)
  phone                    String?   @db.VarChar(20)
  phoneVerifiedAt          DateTime? @map("phone_verified_at") @db.Timestamptz
  departmentId             String?   @map("department_id") @db.Uuid
  title                    String?   @db.VarChar(100)
  role                     UserRole
  // Esas Yönetici'nin bir PERSONELE verdiği EK yönetici (hastane-admin) yetkisi.
  // Kişi role='staff' olarak KALIR (eğitim almaya devam eder) ama /admin paneline erişir.
  // Yetki kararı TEK kaynaktan: lib/auth/admin-authority.ts hasAdminAuthority(). JWT'ye
  // app_metadata.admin_access olarak yansır (middleware oradan okur). super_admin ASLA
  // grant ile verilmez. Yalnız role='staff' için anlamlı; maxAdmins limitine sayılır.
  adminAccessGranted       Boolean   @default(false) @map("admin_access_granted")
  avatarUrl                String?   @map("avatar_url") @db.Text
  isActive                 Boolean   @default(true) @map("is_active")
  // Kullanıcının pasifleştirildiği (isActive=false yapıldığı) an. KVKK saklama-süresi imha
  // cron'u (api/cron/cleanup) bunu kullanır: dataRetentionDays'i aşan pasif personeli otomatik
  // anonimleştirir. Aktifleştirmede null'a döner. Aktif kullanıcıda null.
  deactivatedAt            DateTime? @map("deactivated_at") @db.Timestamptz
  // TC Kimlik No — KVKK gereği AES-256-GCM ile şifrelenmiş + HMAC-SHA256 ile hash'lenmiş.
  // tcEncrypted: ciphertext (görüntüleme için decrypt). tcHash: deterministic, lookup için.
  tcEncrypted              String?   @map("tc_encrypted") @db.Text
  tcHash                   String?   @map("tc_hash") @db.VarChar(64)
  tcAddedAt                DateTime? @map("tc_added_at") @db.Timestamptz
  tcAddedBy                String?   @map("tc_added_by") @db.Uuid
  kvkkNoticeAcknowledgedAt DateTime? @map("kvkk_notice_acknowledged_at") @db.Timestamptz
  // Onaylanan aydınlatma metni sürümü. KVKK_NOTICE_VERSION artınca (metin güncellenince)
  // middleware kullanıcıyı yeniden onaya yönlendirir. null = hiç onaylanmamış / eski kayıt.
  kvkkNoticeVersion        Int?      @map("kvkk_notice_version")
  mustChangePassword       Boolean   @default(false) @map("must_change_password")
  termsAccepted            Boolean   @default(false) @map("terms_accepted")
  termsAcceptedAt          DateTime? @map("terms_accepted_at") @db.Timestamptz
  hireDate                 DateTime? @map("hire_date") @db.Timestamptz
  // İK/HBYS entegrasyonunun dış eşleme anahtarı (personel/sicil no). null = manuel kayıt.
  // Entegrasyon SADECE externalId'li kullanıcıları yönetir (deaktive dahil) —
  // manuel eklenen personele/adminlere asla dokunmaz (ingest.ts planSync).
  externalId               String?   @map("external_id") @db.VarChar(100)
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization                  Organization?                @relation(fields: [organizationId], references: [id])
  departmentRel                 Department?                  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdTrainings              Training[]                   @relation("TrainingCreator")
  assignments                   TrainingAssignment[]         @relation("AssignedUser")
  assignedBy                    TrainingAssignment[]         @relation("AssignedByUser")
  examAttempts                  ExamAttempt[]
  videoProgress                 VideoProgress[]
  notifications                 Notification[]
  sentNotifications             Notification[]               @relation("NotificationSender")
  auditLogs                     AuditLog[]
  certificates                  Certificate[]
  kvkkRequests                  KvkkRequest[]                @relation("KvkkRequester")
  kvkkResponses                 KvkkRequest[]                @relation("KvkkResponder")
  scormAttempts                 ScormAttempt[]
  smgActivities                 SmgActivity[]                @relation("UserSmgActivities")
  smgApprovals                  SmgActivity[]                @relation("SmgApprovals")
  smgTargetOverrides            SmgTarget[]                  @relation("SmgTargetOverrides")
  mediaAssets                   MediaAsset[]                 @relation("MediaAssetUploader")
  subjectEvaluations            CompetencyEvaluation[]       @relation("EvaluationSubject")
  evaluatorEvaluations          CompetencyEvaluation[]       @relation("EvaluationEvaluator")
  pushSubscriptions             PushSubscription[]
  expoPushTokens                ExpoPushToken[]
  expoPushTickets               ExpoPushTicket[]
  accreditationReports          AccreditationReport[]
  createdAccreditationStandards AccreditationStandard[]      @relation("AccreditationStandardCreator")
  // EY.FR.40 Eğitim Geri Bildirim
  feedbackResponses             TrainingFeedbackResponse[]
  // SMS MFA — güvenilir cihazlar
  trustedDevices                TrustedDevice[]
  // Ek deneme hakkı talepleri
  attemptRequests               ExamAttemptRequest[]         @relation("AttemptRequester")
  reviewedAttemptRequests       ExamAttemptRequest[]         @relation("AttemptRequestReviewer")
  // Eğitim dönemi yönetimi
  closedPeriods                 TrainingPeriod[]             @relation("PeriodClosedBy")
  // Esas Yönetici olduğu organizasyon (max 1)
  ownedOrganization             Organization?                @relation("OrganizationOwner")
  // Davet token'ları (gönderdiği + kabul ettiği)
  invitationsSent               Invitation[]                 @relation("InvitationsInvitedBy")
  invitationsAccepted           Invitation[]                 @relation("InvitationsAcceptedBy")
  // Oyunlaştırma Faz 1 — Günün Soruları (spaced-repetition). SMG'den AYRI sistem.
  dailyReviews                  DailyReview[]
  dailySubmissions              DailySubmission[]
  // Oyunlaştırma Faz 2 — Puan / Streak / Rozet
  pointLedger                   PointLedger[]
  streak                        UserStreak?
  userBadges                    UserBadge[]

  // TC ile login lookup (subdomain → orgId → tcHash) için composite unique.
  // Aynı TC farklı kurumlarda olabilir (doktor 2 hastanede çalışabilir),
  // o yüzden global unique değil, organizationId+tcHash composite unique.
  @@unique([organizationId, tcHash], name: "user_org_tc_unique", map: "idx_users_org_tc_unique")
  // İK entegrasyonu dış anahtarı org içinde benzersiz (NULL'lar serbest — Postgres
  // unique index NULL satırları çakıştırmaz; eski his_external_id partial-index deseni).
  @@unique([organizationId, externalId], name: "user_org_external_unique", map: "idx_users_org_external_unique")
  @@index([organizationId], map: "idx_users_org")
  @@index([role], map: "idx_users_role")
  @@index([departmentId], map: "idx_users_department")
  // Performance: composite indexes for filtered queries
  @@index([organizationId, isActive], map: "idx_users_org_active")
  @@index([organizationId, departmentId], map: "idx_users_org_department")
  @@index([organizationId, role], map: "idx_users_org_role")
  @@index([tcHash], map: "idx_users_tc_hash")
  @@map("users")
}

// ── EĞİTİMLER ──
model Training {
  id                  String    @id @default(uuid()) @db.Uuid
  organizationId      String    @map("organization_id") @db.Uuid
  title               String    @db.VarChar(500)
  description         String?   @db.Text
  category            String?   @db.VarChar(100)
  thumbnailUrl        String?   @map("thumbnail_url") @db.Text
  passingScore        Int       @default(70) @map("passing_score")
  maxAttempts         Int       @default(3) @map("max_attempts")
  feedbackMandatory   Boolean   @default(false) @map("feedback_mandatory")
  examDurationMinutes Int       @default(30) @map("exam_duration_minutes")
  startDate           DateTime  @map("start_date") @db.Timestamptz
  endDate             DateTime  @map("end_date") @db.Timestamptz
  isActive            Boolean   @default(true) @map("is_active")
  // G5.4 — Yayın durumu: draft | published | archived
  publishStatus       String    @default("published") @map("publish_status") @db.VarChar(20)
  // Compliance / Uyum Alanları
  isCompulsory        Boolean   @default(false) @map("is_compulsory")
  complianceDeadline  DateTime? @map("compliance_deadline") @db.Timestamptz
  regulatoryBody      String?   @map("regulatory_body") @db.VarChar(200)
  renewalPeriodMonths Int?      @map("renewal_period_months")
  smgPoints           Int       @default(10) @map("smg_points")
  instructorName      String?   @map("instructor_name") @db.VarChar(255)
  createdById         String?   @map("created_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // SCORM alanları
  scormManifestPath String? @map("scorm_manifest_path") @db.Text
  scormEntryPoint   String? @map("scorm_entry_point") @db.Text
  scormVersion      String? @map("scorm_version") @db.VarChar(10)

  // Bağımsız Sınav
  examOnly              Boolean @default(false) @map("exam_only")
  // Default false: mevcut davranışı korur (retry'da pre-exam atlanır).
  // Admin true yaparsa retry'da da pre-exam yapılır.
  requirePreExamOnRetry Boolean @default(false) @map("require_pre_exam_on_retry")
  // Default true: mevcut davranışı korur (sorular her zaman karıştırılır).
  // Admin false yaparsa sorular sortOrder'a göre sabit sırada gelir.
  randomizeQuestions    Boolean @default(true) @map("randomize_questions")
  randomQuestionCount   Int?    @map("random_question_count")

  // Wizard taslak state'i — publishStatus='draft' iken full snapshot.
  // Yayın sonrası tutulur (ileride re-edit içinde reuse) ama yayın akışı bu kolonu okumaz.
  draftData      Json?     @map("draft_data")
  draftStep      Int?      @default(1) @map("draft_step")
  draftUpdatedAt DateTime? @map("draft_updated_at") @db.Timestamptz

  organization      Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdBy         User?                      @relation("TrainingCreator", fields: [createdById], references: [id], onDelete: SetNull)
  videos            TrainingVideo[]
  questions         Question[]
  assignments       TrainingAssignment[]
  examAttempts      ExamAttempt[]
  notifications     Notification[]
  certificates      Certificate[]
  scormAttempts     ScormAttempt[]
  departmentRules   DepartmentTrainingRule[]
  // EY.FR.40 Eğitim Geri Bildirim
  feedbackResponses TrainingFeedbackResponse[]
  // Ek deneme hakkı talepleri
  attemptRequests   ExamAttemptRequest[]

  @@index([organizationId], map: "idx_trainings_org")
  @@index([startDate, endDate], map: "idx_trainings_dates")
  // Performance: composite indexes for filtered queries
  @@index([organizationId, publishStatus], map: "idx_trainings_org_publish_status")
  @@index([organizationId, isCompulsory], map: "idx_trainings_org_compulsory")
  @@index([organizationId, createdAt], map: "idx_trainings_org_created")
  @@index([organizationId, startDate, endDate], map: "idx_trainings_org_start_end")
  // Taslaklar listesi: createdById + publishStatus='draft' lookup
  @@index([organizationId, createdById, publishStatus], map: "idx_trainings_org_creator_publish")
  @@map("trainings")
}

// ── EĞİTİM İÇERİKLERİ (Video + PDF + Audio) ──
model TrainingVideo {
  id              String   @id @default(uuid()) @db.Uuid
  trainingId      String   @map("training_id") @db.Uuid
  title           String   @db.VarChar(500)
  description     String?  @db.Text
  videoUrl        String   @map("video_url") @db.Text
  videoKey        String   @map("video_key") @db.Text
  documentKey     String?  @map("document_key") @db.Text
  durationSeconds Int      @map("duration_seconds")
  contentType     String   @default("video") @map("content_type") @db.VarChar(20) // 'video' | 'pdf' | 'audio'
  pageCount       Int?     @map("page_count")
  fileSizeBytes   BigInt?  @map("file_size_bytes")
  sortOrder       Int      @default(0) @map("sort_order")
  // Medya Kütüphanesinden seçildiyse kaynak asset'e soft geri-bağ (silme engellemez,
  // yalnız "N eğitimde kullanılıyor" rozeti + S3 referans-kontrolü için).
  sourceMediaAssetId String? @map("source_media_asset_id") @db.Uuid
  // Otomatik video transkripti (AI soru üretimi kaynağı). Kanonik kaynak S3'teki
  // transcripts/{orgId}/{seg}/{uuid}.txt dosyasıdır (videoKey'den türetilir);
  // bu kolonlar published satırlar için cache'tir — transcribe Lambda + cron backfill yazar.
  transcriptKey    String? @map("transcript_key") @db.Text
  transcriptStatus String? @map("transcript_status") @db.VarChar(20) // 'completed' | 'failed'
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  training        Training        @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  sourceMediaAsset MediaAsset?    @relation("TrainingVideoFromMediaAsset", fields: [sourceMediaAssetId], references: [id], onDelete: SetNull)
  videoProgress   VideoProgress[]

  @@index([trainingId], map: "idx_training_videos_training")
  @@index([sourceMediaAssetId], map: "idx_training_videos_source_media_asset")
  @@map("training_videos")
}

// ── SORULAR ──
model Question {
  id           String   @id @default(uuid()) @db.Uuid
  trainingId   String   @map("training_id") @db.Uuid
  questionText String   @map("question_text") @db.Text
  questionType String   @default("multiple_choice") @map("question_type") @db.VarChar(20)
  points       Int      @default(10)
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  training     Training         @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  options      QuestionOption[]
  examAnswers  ExamAnswer[]
  dailyReviews DailyReview[]

  @@index([trainingId], map: "idx_questions_training")
  @@map("questions")
}

// ── ŞIKLAR ──
model QuestionOption {
  id         String   @id @default(uuid()) @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  optionText String   @map("option_text") @db.Text
  isCorrect  Boolean  @default(false) @map("is_correct")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  question    Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  examAnswers ExamAnswer[]

  @@index([questionId], map: "idx_question_options_question")
  @@map("question_options")
}

// ── EĞİTİM ATAMALARI ──
model TrainingAssignment {
  id                   String    @id @default(uuid()) @db.Uuid
  trainingId           String    @map("training_id") @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  // Denormalize: training.organizationId'den doldurulur. Cross-tenant query
  // guard'larını tek alana indirir (training join'i olmadan filter).
  organizationId       String    @map("organization_id") @db.Uuid
  periodId             String?   @map("period_id") @db.Uuid
  status               String    @default("assigned") @db.VarChar(30)
  currentAttempt       Int       @default(0) @map("current_attempt")
  maxAttempts          Int       @default(3) @map("max_attempts")
  originalMaxAttempts  Int       @default(3) @map("original_max_attempts")
  assignedById         String?   @map("assigned_by") @db.Uuid
  assignedAt           DateTime  @default(now()) @map("assigned_at") @db.Timestamptz
  completedAt          DateTime? @map("completed_at") @db.Timestamptz
  // Tekrar atama (2. tur) — aynı eğitim + aynı dönem içinde 1, 2, 3 ... round.
  // round=1 = orijinal atama; round=2+ = admin tarafından açılan takip turu.
  round                Int       @default(1) @map("round")
  // Per-atama deadline override. null ise training.endDate fallback.
  // 2. tur açıldığında bu kişilere özel yeni vade.
  dueDate              DateTime? @map("due_date") @db.Timestamptz
  // 2. tur açılış sebebi (audit/rapor): 'failed' | 'no_show' | 'overdue_in_progress'.
  reassignmentReason   String?   @map("reassignment_reason") @db.VarChar(20)
  // Önceki turun id'si — denetim zinciri.
  previousAssignmentId String?   @map("previous_assignment_id") @db.Uuid
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  training           Training             @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  user               User                 @relation("AssignedUser", fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedBy         User?                @relation("AssignedByUser", fields: [assignedById], references: [id])
  period             TrainingPeriod?      @relation(fields: [periodId], references: [id], onDelete: SetNull)
  previousAssignment TrainingAssignment?  @relation("AssignmentRounds", fields: [previousAssignmentId], references: [id], onDelete: SetNull)
  nextRounds         TrainingAssignment[] @relation("AssignmentRounds")
  examAttempts       ExamAttempt[]

  @@unique([trainingId, userId, periodId, round])
  @@index([userId], map: "idx_assignments_user")
  @@index([trainingId], map: "idx_assignments_training")
  @@index([organizationId], map: "idx_assignments_organization")
  @@index([status], map: "idx_assignments_status")
  @@index([userId, status], map: "idx_assignments_user_status")
  @@index([trainingId, status], map: "idx_assignments_training_status")
  @@index([completedAt], map: "idx_assignments_completed_at")
  @@index([periodId], map: "idx_assignments_period")
  @@index([trainingId, round], map: "idx_assignments_training_round")
  @@map("training_assignments")
}

// ── SINAV DENEMELERİ ──
model ExamAttempt {
  id                  String    @id @default(uuid()) @db.Uuid
  assignmentId        String    @map("assignment_id") @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  trainingId          String    @map("training_id") @db.Uuid
  attemptNumber       Int       @map("attempt_number")
  preExamScore        Decimal?  @map("pre_exam_score") @db.Decimal(5, 2)
  postExamScore       Decimal?  @map("post_exam_score") @db.Decimal(5, 2)
  preExamStartedAt    DateTime? @map("pre_exam_started_at") @db.Timestamptz
  preExamCompletedAt  DateTime? @map("pre_exam_completed_at") @db.Timestamptz
  postExamStartedAt   DateTime? @map("post_exam_started_at") @db.Timestamptz
  postExamCompletedAt DateTime? @map("post_exam_completed_at") @db.Timestamptz
  videosCompletedAt   DateTime? @map("videos_completed_at") @db.Timestamptz
  isPassed            Boolean   @default(false) @map("is_passed")
  status              String    @default("pre_exam") @db.VarChar(30)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  signedAt            DateTime? @map("signed_at") @db.Timestamptz
  signatureData       String?   @map("signature_data") @db.Text
  signatureIp         String?   @map("signature_ip") @db.VarChar(45)
  signatureMethod     String?   @map("signature_method") @db.VarChar(20)
  organizationId      String    @map("organization_id") @db.Uuid
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  assignment       TrainingAssignment        @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user             User                      @relation(fields: [userId], references: [id])
  training         Training                  @relation(fields: [trainingId], references: [id])
  organization     Organization              @relation(fields: [organizationId], references: [id])
  examAnswers      ExamAnswer[]
  videoProgress    VideoProgress[]
  certificates     Certificate[]
  // EY.FR.40 Eğitim Geri Bildirim (attempt başına 1 yanıt)
  feedbackResponse TrainingFeedbackResponse?

  @@unique([assignmentId, attemptNumber])
  @@index([assignmentId], map: "idx_attempts_assignment")
  @@index([userId], map: "idx_attempts_user")
  @@index([trainingId], map: "idx_attempts_training")
  @@index([trainingId, status], map: "idx_attempts_training_status")
  @@index([userId, trainingId], map: "idx_attempts_user_training")
  @@index([userId, status], map: "idx_attempts_user_status")
  @@index([assignmentId, status], map: "idx_attempts_assignment_status")
  @@index([userId, isPassed], map: "idx_attempts_user_passed")
  @@index([organizationId], map: "idx_attempts_organization")
  @@map("exam_attempts")
}

// ── EK DENEME HAKKI TALEPLERİ ──
// Personel sınav haklarını tükettiğinde admin'den ek hak talep eder.
// status: pending | approved | rejected
model ExamAttemptRequest {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  trainingId      String    @map("training_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  reason          String?   @db.Text
  status          String    @default("pending") @db.VarChar(20)
  reviewedById    String?   @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime? @map("reviewed_at") @db.Timestamptz
  grantedAttempts Int?      @map("granted_attempts")
  reviewNote      String?   @map("review_note") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  training     Training     @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  user         User         @relation("AttemptRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy   User?        @relation("AttemptRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([organizationId, status], map: "idx_attempt_requests_org_status")
  @@index([userId], map: "idx_attempt_requests_user")
  @@index([trainingId], map: "idx_attempt_requests_training")
  @@index([userId, trainingId, status], map: "idx_attempt_requests_user_training_status")
  @@map("exam_attempt_requests")
}

// ── SINAV CEVAPLARI ──
model ExamAnswer {
  id               String   @id @default(uuid()) @db.Uuid
  attemptId        String   @map("attempt_id") @db.Uuid
  questionId       String   @map("question_id") @db.Uuid
  selectedOptionId String?  @map("selected_option_id") @db.Uuid
  isCorrect        Boolean? @map("is_correct")
  examPhase        String   @map("exam_phase") @db.VarChar(10)
  answeredAt       DateTime @default(now()) @map("answered_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  attempt        ExamAttempt     @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question        @relation(fields: [questionId], references: [id])
  selectedOption QuestionOption? @relation(fields: [selectedOptionId], references: [id])

  @@unique([attemptId, questionId, examPhase])
  @@index([attemptId], map: "idx_exam_answers_attempt")
  @@map("exam_answers")
}

// ── VİDEO İZLEME TAKİBİ ──
model VideoProgress {
  id                  String    @id @default(uuid()) @db.Uuid
  attemptId           String    @map("attempt_id") @db.Uuid
  videoId             String    @map("video_id") @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  watchedSeconds      Int       @default(0) @map("watched_seconds")
  totalSeconds        Int       @map("total_seconds")
  isCompleted         Boolean   @default(false) @map("is_completed")
  lastPositionSeconds Int       @default(0) @map("last_position_seconds")
  completedAt         DateTime? @map("completed_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  attempt ExamAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  video   TrainingVideo @relation(fields: [videoId], references: [id])
  user    User          @relation(fields: [userId], references: [id])

  @@unique([attemptId, videoId])
  // Performance: composite index for user video progress lookups
  @@index([userId, videoId], map: "idx_video_progress_user_video")
  @@index([userId, isCompleted], map: "idx_video_progress_user_completed")
  @@map("video_progress")
}

// ── BİLDİRİMLER ──
model Notification {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  organizationId    String?  @map("organization_id") @db.Uuid
  // Admin tarafından manuel gönderilen bildirimlerde dolu, sistem (sınav,
  // atama, cron, abonelik) tarafından üretilenlerde NULL kalır. Admin
  // bildirim panelinde sadece kendi gönderdiklerini görmek için filtre.
  senderId          String?  @map("sender_id") @db.Uuid
  // Admin manuel gönderiminde aynı UUID, tüm alıcı satırlarına yazılır.
  // Sistem bildirimleri (sınav/atama/cron/abonelik) NULL kalır.
  // Admin panel listesi bu kolonla "gönderim başına tek kart" olarak gruplar.
  batchId           String?  @map("batch_id") @db.Uuid
  title             String   @db.VarChar(500)
  message           String   @db.Text
  type              String   @db.VarChar(50)
  relatedTrainingId String?  @map("related_training_id") @db.Uuid
  isRead            Boolean  @default(false) @map("is_read")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sender          User?         @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)
  organization    Organization? @relation(fields: [organizationId], references: [id])
  relatedTraining Training?     @relation(fields: [relatedTrainingId], references: [id])

  @@index([userId, isRead], map: "idx_notifications_user")
  @@index([userId, createdAt], map: "idx_notifications_user_date")
  @@index([organizationId, isRead, createdAt], map: "idx_notifications_org_read_date")
  // Performance: composite index for org-wide notification queries sorted by date
  @@index([organizationId, createdAt], map: "idx_notifications_org_date")
  // Admin "Gönderdiklerim" listesinde senderId + org filtresi
  @@index([senderId, createdAt], map: "idx_notifications_sender_date")
  // Batch grouping (admin "Gönderdiklerim" listesi + batch detay endpoint'i)
  @@index([batchId], map: "idx_notifications_batch")
  @@index([senderId, batchId, createdAt], map: "idx_notifications_sender_batch")
  @@map("notifications")
}

// ── DENETİM KAYITLARI ──
model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  action         String   @db.VarChar(100)
  entityType     String   @map("entity_type") @db.VarChar(50)
  entityId       String?  @map("entity_id") @db.Uuid
  oldData        Json?    @map("old_data")
  newData        Json?    @map("new_data")
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  userAgent      String?  @map("user_agent") @db.Text
  hash           String?  @db.VarChar(64)
  prevHash       String?  @map("prev_hash") @db.VarChar(64)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId], map: "idx_audit_logs_user")
  @@index([entityType, entityId], map: "idx_audit_logs_entity")
  @@index([createdAt], map: "idx_audit_logs_date")
  @@index([organizationId, createdAt], map: "idx_audit_logs_org_date")
  // Performance: composite index for user activity timeline
  @@index([userId, createdAt], map: "idx_audit_logs_user_date")
  @@map("audit_logs")
}

// ── İLETİŞİM / DEMO TALEP MESAJLARI ──
// Platform geneli (tenant-dışı) gelen mesajlar. Web sitesindeki iletişim formu
// ve demo talep formu buraya yazılır. organizationId YOK — henüz müşteri olmayan
// kişilerden gelir. Sadece super_admin görür (RLS: super_admin_contact_messages_all).
model ContactMessage {
  id           String    @id @default(uuid()) @db.Uuid
  source       String    @default("contact") @db.VarChar(30) // 'contact' | 'demo'
  name         String    @db.VarChar(200)
  email        String    @db.VarChar(200)
  phone        String?   @db.VarChar(30)
  organization String?   @db.VarChar(200)
  staffCount   String?   @map("staff_count") @db.VarChar(20)
  subject      String?   @db.VarChar(300)
  message      String?   @db.Text
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  isRead       Boolean   @default(false) @map("is_read")
  isArchived   Boolean   @default(false) @map("is_archived")
  readAt       DateTime? @map("read_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([isRead, createdAt], map: "idx_contact_messages_unread")
  @@index([source, createdAt], map: "idx_contact_messages_source")
  @@map("contact_messages")
}

// ── VERİTABANI YEDEKLERİ ──
model DbBackup {
