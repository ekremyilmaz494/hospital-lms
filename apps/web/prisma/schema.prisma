  organizationId String?  @map("organization_id") @db.Uuid
  backupType     String   @map("backup_type") @db.VarChar(20)
  fileUrl        String   @map("file_url") @db.Text
  fileSizeMb     Decimal? @map("file_size_mb") @db.Decimal(10, 2)
  fileSize       Int?     @map("file_size")
  verified       Boolean  @default(false) @map("verified")
  status         String   @default("completed") @db.VarChar(20)
  createdById    String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@map("db_backups")
}

// ── SERTİFİKALAR ──
model Certificate {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  trainingId       String    @map("training_id") @db.Uuid
  // D1b — Sertifika ya bir ExamAttempt'e (sınavlı eğitim) YA da bir ScormAttempt'e
  // (saf SCORM) bağlanır. İkisi de @unique + nullable; tam olarak biri set edilir
  // (uygulama katmanında zorlanır). Eskiden attemptId NOT NULL'dı → saf SCORM'a
  // sertifika üretilemiyordu.
  attemptId        String?   @unique @map("attempt_id") @db.Uuid
  scormAttemptId   String?   @unique @map("scorm_attempt_id") @db.Uuid
  certificateCode  String    @unique @map("certificate_code") @db.VarChar(50)
  issuedAt         DateTime  @default(now()) @map("issued_at") @db.Timestamptz
  expiresAt        DateTime? @map("expires_at") @db.Timestamptz
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  revocationReason String?   @map("revocation_reason") @db.VarChar(500)
  // Tenant izolasyonu — NOT NULL: her sertifika bir organizasyona ait (training üzerinden
  // backfill edildi). onDelete Restrict (Training.organization ile aynı): sertifikası olan org
  // hard-delete edilemez (super_admin askıya alır, silmez).
  organizationId   String    @map("organization_id") @db.Uuid
  periodId         String?   @map("period_id") @db.Uuid
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user         User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  training     Training        @relation(fields: [trainingId], references: [id], onDelete: Restrict)
  attempt      ExamAttempt?    @relation(fields: [attemptId], references: [id], onDelete: Restrict)
  scormAttempt ScormAttempt?   @relation(fields: [scormAttemptId], references: [id], onDelete: Restrict)
  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  period       TrainingPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@index([userId], map: "idx_certificates_user")
  @@index([trainingId], map: "idx_certificates_training")
  @@index([organizationId], map: "idx_certificates_organization")
  @@index([periodId], map: "idx_certificates_period")
  @@map("certificates")
}

