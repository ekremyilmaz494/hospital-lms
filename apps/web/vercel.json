{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["fra1"],
  "buildCommand": "pnpm build:prod",
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/backup",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/verify-backup",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/expo-receipts",
      "schedule": "15 4 * * *"
    },
    {
      "path": "/api/cron/subscription-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/compliance-report",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/period-rollover",
      "schedule": "0 1 1 1 *"
    },
    {
      "path": "/api/cron/daily-quiz-push",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/streak-maintenance",
      "schedule": "5 21 * * *"
    },
    {
      "path": "/api/cron/staff-sync",
      "schedule": "30 5 * * *"
    }
  ]
}
