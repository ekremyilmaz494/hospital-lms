# ─────────────────────────────────────────────────────────────────────────────
# KlinoVax on-prem .env — install.sh bu dosyayı sizin için ÜRETİR (sırları
# rastgele oluşturur). Elle düzenlemek isterseniz şablon budur.
# ⚠️ Bu dosyayı ASLA versiyon kontrolüne eklemeyin — sır içerir.
# ─────────────────────────────────────────────────────────────────────────────

# ── İmaj ──
APP_IMAGE=klinovax/hospital-lms:onprem

# ── Erişim (müşteri sunucusunun DIŞ adresleri) ──
# Tarayıcıdan erişilen public URL'ler. TLS önerilir (reverse proxy arkası).
PUBLIC_APP_URL=http://localhost:3000
BASE_DOMAIN=localhost:3000
PUBLIC_STORAGE_URL=http://localhost:9000
# Sunucu-taraf DOĞRUDAN S3 işlemleri için İÇ adres (container→MinIO). Varsayılan
# iç Docker servisi (http://minio:9000) — dokunmaya gerek yok. Yalnız DIŞ bir S3/MinIO
# kullanıyorsanız o URL'ye ayarlayın (aksi halde upload/multipart/yedek kırılır).
# S3_INTERNAL_ENDPOINT=http://minio:9000

# ── TLS (gömülü Caddy reverse-proxy) — install.sh sorar ──
# TLS AÇIK: PUBLIC_APP_URL=https://<host>, PUBLIC_STORAGE_URL=https://<host>:9443,
# COMPOSE_PROFILES=tls (proxy başlar), SERVICE_BIND=127.0.0.1 (doğrudan portlar LAN'a KAPALI),
# CADDY_MAIN_SITE=<host>, CADDY_STORAGE_SITE=<host>:9443.
# TLS KAPALI (varsayılan): SERVICE_BIND=0.0.0.0, COMPOSE_PROFILES boş.
SERVICE_BIND=0.0.0.0
COMPOSE_PROFILES=
CADDY_MAIN_SITE=
CADDY_STORAGE_SITE=
HTTPS_PORT=443
HTTPS_STORAGE_PORT=9443
APP_PORT=3000
GATEWAY_PORT=8000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MAILPIT_UI_PORT=8025

# ── Postgres ──
POSTGRES_PASSWORD=CHANGE_ME

# ── Supabase Auth/Realtime (self-hosted) ──
# JWT_SECRET min 32 karakter. ANON_KEY/SERVICE_ROLE_KEY bununla imzalı JWT'lerdir
# (install.sh üretir; elle üretmeyin — imza JWT_SECRET'e bağlıdır).
# REALTIME_ENC_KEY: TAM 16 karakter ZORUNLU (Realtime AES-128 DB_ENC_KEY; ≠16 → crash-loop).
#                   Üret: openssl rand -base64 12 | tr '+/' '-_'
# REALTIME_SECRET_KEY_BASE: 64 karakter (openssl rand -hex 32).
JWT_SECRET=CHANGE_ME_min_32_char_secret_string
ANON_KEY=CHANGE_ME_signed_anon_jwt
SERVICE_ROLE_KEY=CHANGE_ME_signed_service_jwt
REALTIME_ENC_KEY=CHANGE_ME_16char
REALTIME_SECRET_KEY_BASE=CHANGE_ME_64_hex_chars

# ── MinIO (nesne deposu) ──
MINIO_ROOT_USER=klinovax
MINIO_ROOT_PASSWORD=CHANGE_ME
S3_BUCKET=klinovax-media

# ── Redis / SRH ──
SRH_TOKEN=CHANGE_ME

# ── E-posta (SMTP) ── Varsayılan mailpit (yakalar, göndermez). Prod'da müşteri relay'i:
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@klinovax.local
# Yedek/yedek-doğrulama cron'u başarısızlıkta buraya alarm e-postası atar. BOŞSA
# alarm GİTMEZ (yalnız log/Sentry backstop) — yedek arızasının fark edilmesi için doldurun.
ADMIN_ALERT_EMAIL=

# ── Güvenlik/altyapı ──
# DİKKAT: ENCRYPTION_KEY ve BACKUP_ENCRYPTION_KEY FARKLI formatlardır — karıştırmayın:
#   ENCRYPTION_KEY        = base64(32 byte)  → node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   BACKUP_ENCRYPTION_KEY = 64 HEX karakter  → openssl rand -hex 32   (base64 KABUL EDİLMEZ → yedek her seferinde kırılır)
CRON_SECRET=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME_base64_32_bytes
BACKUP_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars
HEALTH_CHECK_SECRET=CHANGE_ME

# ── Lisans (dışarıya TEK bağlantı) ──
LICENSE_SERVER_URL=https://app.klinovax.com

# ── İlk süper-admin (ilk boot'ta oluşturulur) ──
ONPREM_ADMIN_EMAIL=admin@hastane.local
ONPREM_ADMIN_PASSWORD=CHANGE_ME
