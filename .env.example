# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (Supabase PostgreSQL) ───
# DATABASE_URL → Transaction Pooler (port 6543) — runtime queries (Prisma Client)
# DIRECT_URL   → Session Pooler (port 5432) — migration/DDL (Prisma CLI)
# NOT: "db.your-project.supabase.co:5432" host'u IPv6-only — IPv4 agdan baglanamaz.
#      Supabase Dashboard → Settings → Database → Connection string → "Session" sekmesi
DATABASE_URL=postgresql://postgres.your-project:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=20
DIRECT_URL=postgresql://postgres.your-project:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
HEALTH_CHECK_SECRET=generate-a-random-secret

# ─── AWS S3 + CloudFront (video) ───
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY=

# ─── Upstash Redis ───
REDIS_URL=https://your-redis.upstash.io
REDIS_TOKEN=your-redis-token

# ─── Cron Security ───
CRON_SECRET=generate-a-random-hex-string

# ─── SMTP (Email) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Hastane LMS <your-email@gmail.com>
SMTP_REPLY_TO=destek@hastanelms.com

# ─── Web Push (VAPID) ───
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ─── Sentry (Error Monitoring) ───
# DSN'leri Sentry projeni olusturduktan sonra al: https://sentry.io/settings/<org>/projects/<proj>/keys/
# NEXT_PUBLIC_SENTRY_DSN → browser'da init icin (client)
# SENTRY_DSN             → server + edge runtime icin
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oyyy.ingest.sentry.io/zzzz
SENTRY_DSN=https://xxxx@oyyy.ingest.sentry.io/zzzz
# Source map upload icin (next.config.ts withSentryConfig)
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=hospital-lms
# Sentry Settings → Developer Settings → Auth Tokens → "project:write" scope'lu token
SENTRY_AUTH_TOKEN=sntrys_xxxx

# ─── Misc ───
NEXT_PUBLIC_BASE_DOMAIN=localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=destek@hastanelms.com
ADMIN_ALERT_EMAIL=alert@hastanelms.com
BACKUP_ENCRYPTION_KEY=generate-a-random-32-char-key
ENCRYPTION_KEY=generate-a-random-hex-string-for-his-integration
