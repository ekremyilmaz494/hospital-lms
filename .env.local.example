# ════════════════════════════════════════════════════════════════════════
#  .env.local.example — YEREL GELİŞTİRME ortamı şablonu
# ════════════════════════════════════════════════════════════════════════
#
#  Bu şablon, geliştirmenin LOCAL SUPABASE'e (Docker) bağlanması içindir —
#  ASLA production'a değil. 2026-05-20 incident'inin kök nedeni, laptoptaki
#  `.env.local`'in production'a bakmasıydı; bu dosya o hatayı yapısal olarak
#  önler: yerel ortamda prod credential'ı hiç bulunmaz.
#
#  Kurulum adımları için: docs/local-development.md
#
#  Kullanım:
#    1. `supabase start` çalıştır (Docker gerekli)
#    2. Bu dosyayı `.env.local` olarak kopyala
#    3. Aşağıdaki <...> alanlarını `supabase start` çıktısıyla doldur
# ════════════════════════════════════════════════════════════════════════

# ─── Supabase (LOCAL — supabase start) ───
# API URL ve portlar local stack'te sabittir. Anahtarları `supabase start`
# (veya `supabase status`) çıktısından kopyala.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase start çıktısındaki anon key>
SUPABASE_SERVICE_ROLE_KEY=<supabase start çıktısındaki service_role key>

# ─── Database (LOCAL PostgreSQL — supabase start) ───
# Local stack'te pooler yok; DATABASE_URL ve DIRECT_URL aynı (port 54322).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_DOMAIN=localhost:3000
HEALTH_CHECK_SECRET=local-dev-secret
CRON_SECRET=local-dev-cron-secret

# ─── Şifreleme anahtarları (LOCAL — prod'dakinden FARKLI olmalı) ───
# Local için yeni üret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Prod ENCRYPTION_KEY'ini buraya KOPYALAMA — ortamlar ayrı kalmalı.
ENCRYPTION_KEY=<local için yeni üret — 32 byte base64>
BACKUP_ENCRYPTION_KEY=<local için yeni üret — 32 byte base64>

# ─── Diğer servisler (AWS / Redis / Brevo / Sentry / Web Push) ───
# Local geliştirmede çoğu opsiyoneldir. Gerekirse kendi dev/test
# hesaplarının değerlerini gir — prod değerlerini buraya taşıma.
# Tam liste ve açıklamalar için: .env.example
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_CLOUDFRONT_DOMAIN=
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY=
REDIS_URL=
REDIS_TOKEN=
BREVO_API_KEY=
NEXT_PUBLIC_VAPID_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
ADMIN_ALERT_EMAIL=
